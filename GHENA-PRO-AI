class Leviathan:
    def __init__(self, target):
        self.target = target
        self.healer = AutonomousHealer(target)
        self.results = {}
        self.history = []

    def log(self, cmd, status, out=""):
        self.history.append({
            "timestamp": datetime.now().strftime("%H:%M:%S"),
            "command": cmd,
            "status": status,
            "output_preview": out[:100]
        })

    def run_smart(self, cmd):
        """التنفيذ مع حلقة الذكاء الاصطناعي للتصحيح الذاتي"""
        retries = 2
        current_cmd = cmd

        while retries >= 0:
            print(f"\n{B}{BOLD}[تكتيك]{END} {W}{current_cmd}{END}")
            try:
                proc = subprocess.Popen(shlex.split(current_cmd), stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
                stdout, stderr = proc.communicate(timeout=300)

                if proc.returncode == 0:
                    self.log(current_cmd, "SUCCESS", stdout)
                    return stdout
                else:
                    new_cmd = self.healer.resolve(current_cmd, stderr)
                    if new_cmd and new_cmd != current_cmd:
                        current_cmd = new_cmd
                        retries -= 1
                        continue
                    else:
                        self.log(current_cmd, "FAILED", stderr)
                        print(f"{R}[-] فشل ذريع: {stderr[:150]}{END}")
                        return None
            except Exception as e:
                print(f"{R}[!] خطأ في النظام: {e}{END}")
                return None
        return None

