        # طلب رفع الصلاحيات من المستخدم
        if "permission denied" in err or "uid=" in stdout and "uid=0" not in stdout:
            print(f"\n{R}{BOLD}[!!!] تنبيه: نحن بحاجة لرفع الصلاحيات (Privilege Escalation)!{END}")
