    def run_cmd(self, cmd, timeout=120):
        """تنفيذ أمر وعرضه بشكل احترافي"""
        self.log_expert(f"⚡ Executing: {cmd}", CYAN)
        try:
            result = subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT,
                                           text=True, timeout=timeout)
            return result
        except subprocess.TimeoutExpired:
            self.log_expert("   ⏰ Command timed out. Target may be slow or filtering.", YELLOW)
        except subprocess.CalledProcessError as e:
            self.log_expert(f"   ⚠️ Command failed with code {e.returncode}. This is normal for some probes.", YELLOW)
        except Exception as e:
            self.log_expert(f"   ❌ Error: {e}", YELLOW)
        return ""
        
