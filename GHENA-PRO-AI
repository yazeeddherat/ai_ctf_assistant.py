#!/usr/bin/env python3
import os
import subprocess
import shlex
import requests
import datetime
import re

# =========================
# 🔐 AUTO DETECT API KEY
# =========================
def load_api_key():
    # 1) ENV
    key = os.getenv("OPENAI_API_KEY")

    # 2) .env fallback
    if not key:
        try:
            from dotenv import load_dotenv
            load_dotenv()
            key = os.getenv("OPENAI_API_KEY")
        except:
            pass

    # 3) return or None (offline mode)
    return key

API_KEY = load_api_key()
MODEL = "gpt-4.1-mini"

OFFLINE_MODE = False if API_KEY else True

# =========================
# 🎨 UI
# =========================
G="\033[92m"; Y="\033[93m"; C="\033[96m"; R="\033[91m"; END="\033[0m"

history = []
notes = []

# =========================
# 🧠 AI ENGINE (SAFE)
# =========================
SYSTEM_PROMPT = """
You are a CTF assistant (THM / HTB).
Return ONLY next step, short and practical.
"""

def ask_ai(data):
    global OFFLINE_MODE

    if OFFLINE_MODE:
        return offline_engine(data)

    try:
        history.append({"role":"user","content":data})

        r = requests.post(
            "https://api.openai.com/v1/chat/completions",
            headers={
                "Authorization": f"Bearer {API_KEY}",
                "Content-Type": "application/json"
            },
            json={
                "model": MODEL,
                "messages":[{"role":"system","content":SYSTEM_PROMPT}] + history
            },
            timeout=15
        )

        r.raise_for_status()

        reply = r.json()["choices"][0]["message"]["content"]
        history.append({"role":"assistant","content":reply})
        return reply

    except Exception as e:
        print(f"{R}[AI ERROR → switching offline mode]{END}")
        OFFLINE_MODE = True
        return offline_engine(data)

# =========================
# 📴 OFFLINE AI (NO API)
# =========================
def offline_engine(data):
    text = data.lower()

    # Simple heuristic reasoning
    if "nmap" in text:
        return "Check open ports manually → focus HTTP / SSH / SMB"
    if "login" in text:
        return "Try default creds / brute force / SQL injection check"
    if "upload" in text:
        return "Test file upload bypass (php, burp, extensions)"
    if "uid=" in text:
        return "Run sudo -l and SUID enumeration"
    if "port 80" in text or "http" in text:
        return "Run directory brute force (ffuf / gobuster)"
    
    return "Manual enumeration required (recon deeper)"

# =========================
# ⚙️ RUN COMMAND
# =========================
def run(cmd):
    print(f"{Y}[RUN]{END} {cmd}")
    try:
        p = subprocess.Popen(
            shlex.split(cmd),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True
        )
        out, err = p.communicate(timeout=120)
        return out if out else err
    except Exception as e:
        return str(e)

# =========================
# 🔍 PARSER
# =========================
def parse_nmap(data):
    return re.findall(r'(\d+)/tcp\s+open\s+([^\s]+)', data)

# =========================
# 🌐 WEB HEURISTIC
# =========================
def web_check(target):
    try:
        r = requests.get(f"http://{target}", timeout=5)
        t = r.text.lower()

        if "login" in t:
            return "Login page detected"
        if "upload" in t:
            return "Upload feature found"
        if "?id=" in t:
            return "Possible SQL injection parameter"
        return "No obvious hints"
    except:
        return "Web not reachable"

# =========================
# 🧠 DECISION ENGINE
# =========================
def decide_step(output):
    if "uid=" in output:
        return "Privilege escalation phase"
    if "open" in output:
        return "Enumeration phase"
    return "Recon phase"

# =========================
# 🚀 SOLVER CORE
# =========================
def solver(target):
    print(f"{G}Target:{END} {target}")

    # RECON
    nmap_out = run(f"nmap -sC -sV {target}")
    print(nmap_out[:500])

    ports = parse_nmap(nmap_out)
    print(f"{C}Open Ports:{END} {ports}")

    web = web_check(target)
    print(f"{C}[WEB]{END} {web}")

    output = nmap_out

    # LOOP
    while True:
        phase = decide_step(output)

        print(f"\n{C}[PHASE]{END} {phase}")
        suggestion = ask_ai(f"Phase: {phase}\nOutput:\n{output[:500]}\nWhat next?")

        print(f"{G}[AI]{END} {suggestion}")

        choice = input("(run / save / exit / offline): ").strip()

        if choice == "run":
            output = run(suggestion)

        elif choice == "offline":
            global OFFLINE_MODE
            OFFLINE_MODE = True
            print("[+] Switched to offline mode")

        elif choice == "save":
            notes.append({"time":str(datetime.datetime.now()),"step":suggestion})
            print("[+] saved")

        elif choice == "exit":
            break

# =========================
# 📄 REPORT
# =========================
def report():
    print(f"{Y}\n=== NOTES ==={END}")
    for n in notes:
        print(n)

# =========================
# MAIN
# =========================
def main():
    print(f"""{G}
LEVIATHAN v4 — SMART RESILIENT CTF SOLVER
{END}""")

    print(f"{C}[Mode]{END} {'OFFLINE' if OFFLINE_MODE else 'ONLINE AI'}")

    target = input("Target IP: ").strip()
    solver(target)
    report()

if __name__ == "__main__":
    main()
