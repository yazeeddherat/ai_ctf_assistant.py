    def log(self, message, color=GREEN):
        timestamp = datetime.now().strftime("%H:%M:%S")
        self.output_queue.put(f"[{timestamp}] {message}\n")
        
    def update_output(self):
        try:
            while True:
                msg = self.output_queue.get_nowait()
                self.output_text.insert(tk.END, msg)
                self.output_text.see(tk.END)
        except queue.Empty:
            pass
        self.root.after(100, self.update_output)
        
    def clear_output(self):
        self.output_text.delete(1.0, tk.END)
        
    def save_results(self):
        if not self.current_ip:
            messagebox.showwarning("Warning", "No results to save yet.")
            return
            
        filename = f"GHENA_{self.current_ip}_{int(time.time())}.txt"
        try:
            with open(filename, 'w', encoding='utf-8') as f:
                f.write("="*60 + "\n")
                f.write("GHENA SMART SOLVER - RESULTS\n")
                f.write(f"Target IP: {self.current_ip}\n")
                f.write(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
                f.write("="*60 + "\n\n")
                f.write(f"Open Ports ({len(self.results['ports'])}):\n")
                for p in sorted(self.results['ports']):
                    svc = self.results['services'].get(p, 'unknown')
                    f.write(f"  {p}: {svc}\n")
                f.write("\n")
                if self.results['cms']:
                    f.write(f"CMS: {self.results['cms']}\n\n")
                if self.results['usernames']:
                    f.write("Usernames:\n")
                    for u in sorted(self.results['usernames']):
                        f.write(f"  {u}\n")
                    f.write("\n")
                if self.results['passwords']:
                    f.write("Passwords/Hashes:\n")
                    for p in sorted(self.results['passwords']):
                        f.write(f"  {p}\n")
                    f.write("\n")
                if self.results['flags']:
                    f.write("Flags:\n")
                    for fl in sorted(self.results['flags']):
                        f.write(f"  {fl}\n")
                    f.write("\n")
                if self.results['answers']:
                    f.write("Answers:\n")
                    for ans in self.results['answers']:
                        f.write(f"  {ans}\n")
            messagebox.showinfo("Success", f"Results saved to {filename}")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to save: {e}")
            
    def run_cmd(self, cmd, timeout=120):
        try:
            result = subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT,
                                           text=True, timeout=timeout)
            return result
        except subprocess.TimeoutExpired:
            self.log(f"    ⏰ Command timed out: {cmd[:50]}...")
        except subprocess.CalledProcessError as e:
            self.log(f"    ⚠️ Command failed (code {e.returncode}): {cmd[:50]}...")
        except Exception as e:
            self.log(f"    ❌ Error: {e}")
        return ""
        
    def identify_room(self):
        """محاولة التعرف على الغرفة من قاعدة البيانات باستخدام المنافذ"""
        ports_set = set(self.results["ports"])
        best_match = None
        best_score = 0
        for room_id, data in self.rooms_db.items():
            known_ports = set(data.get("ports", []))
            if not known_ports:
                continue
            score = len(ports_set.intersection(known_ports))
            if score > best_score:
                best_score = score
                best_match = room_id
        if best_match and best_score >= len(self.rooms_db[best_match]["ports"]) * 0.6:
            return best_match
        return None
        
    def display_room_answers(self, room_id):
        data = self.rooms_db[room_id]
        self.log("\n" + "="*60)
        self.log(f"✅ ROOM FOUND IN DB: {data.get('name', room_id)}")
        self.log("="*60)
        if "answers" in data and data["answers"]:
            self.results["answers"] = data["answers"]
            for ans in data["answers"]:
                self.log(f"  ▶️ {ans}")
        else:
            self.log("  No answers in DB for this room.")
            
    # ========== مراحل الفحص الشامل (إذا لم توجد الغرفة في DB) ==========
    def scan_web(self, ip, port):
        protocol = 'https' if port in [443,8443] else 'http'
        self.log(f"    🌐 Scanning web on port {port}...")
        # whatweb
        out = self.run_cmd(f"whatweb {protocol}://{ip}:{port}")
        if out:
            techs = re.findall(r'([A-Za-z0-9]+(?:-[A-Za-z0-9]+)*)\[', out)
            for t in techs:
                self.results["web_techs"].add(t)
        # gobuster سريع
        out = self.run_cmd(f"gobuster dir -u {protocol}://{ip}:{port} -w /usr/share/wordlists/dirb/common.txt -t 50 -q")
        if out:
            dirs = re.findall(r'/(\S+)\s+\(Status: 200\)', out)
            for d in dirs:
                self.results["directories"].add(d)
        # curl الصفحة الرئيسية
        out = self.run_cmd(f"curl -s {protocol}://{ip}:{port}")
        if out:
            cms_keywords = ['WordPress', 'Joomla', 'Drupal', 'Magento', 'Simple Image Gallery', 'CMS Made Simple']
            for cms in cms_keywords:
                if cms.lower() in out.lower():
                    self.results["cms"] = cms
                    break
                    
    def scan_ftp(self, ip):
        if 21 not in self.results["ports"]:
            return
        self.log("    📁 Checking FTP...")
        out = self.run_cmd(f"nmap --script ftp-anon -p 21 {ip}")
        if "Anonymous FTP login allowed" in out:
            self.log("      ✅ FTP anonymous login allowed")
            ftp_out = self.run_cmd(f"echo -e 'anonymous\\n\\nls\\nbye' | ftp -n {ip} 2>/dev/null")
            files = re.findall(r'^-rw-r--r--.*?(\S+)$', ftp_out, re.MULTILINE)
            if files:
                self.log(f"      Files: {', '.join(files)}")
                
    def scan_smb(self, ip):
        if any(p in [139,445] for p in self.results["ports"]):
            self.log("    📁 Checking SMB...")
            out = self.run_cmd(f"enum4linux -a {ip}")
            if out:
                users = re.findall(r'user:\[(\S+)\]', out)
                for u in users:
                    self.results["usernames"].add(u)
                    
    def scan_ssh(self, ip):
        if 22 in self.results["ports"]:
            self.log("    🔐 Checking SSH...")
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(5)
                sock.connect((ip, 22))
                banner = sock.recv(1024).decode()
                sock.close()
                self.log(f"      Banner: {banner.strip()}")
            except:
                pass
                
    def hunt_flags(self, ip, web_ports):
        self.log("    🎯 Hunting for flags...")
        flag_paths = [
            "/flag.txt", "/root/flag.txt", "/root/root.txt", "/root.txt",
            "/home/*/flag.txt", "/home/*/user.txt", "/user.txt",
            "/var/www/flag.txt", "/tmp/flag.txt", "/.flag",
            "/secret.txt"
        ]
        for port in web_ports:
            protocol = 'https' if port in [443,8443] else 'http'
            for path in flag_paths:
                out = self.run_cmd(f"curl -s {protocol}://{ip}:{port}{path}")
                if out and len(out) < 500:
                    patterns = [r'THM\{[^}]+\}', r'flag\{[^}]+\}', r'FLAG\{[^}]+\}',
                                r'G00d j0b', r'W3ll d0n3']
                    for pat in patterns:
                        matches = re.findall(pat, out)
                        for m in matches:
                            self.results["flags"].add(m)
                            self.log(f"      🎯 Found: {m}")
                            
    def extract_info(self):
        for f in Path(".").glob("*.txt"):
            if f.name.startswith("GHENA_"):
                continue
            try:
                content = f.read_text(encoding='utf-8', errors='ignore')
                user_pats = [r'username:\s*(\S+)', r'user:\s*(\S+)', r'login:\s*(\S+)']
                for pat in user_pats:
                    matches = re.findall(pat, content, re.IGNORECASE)
                    for m in matches:
                        self.results["usernames"].add(m.strip())
                pass_pats = [r'password:\s*(\S+)', r'pass:\s*(\S+)', r'([a-f0-9]{32})']
                for pat in pass_pats:
                    matches = re.findall(pat, content, re.IGNORECASE)
                    for m in matches:
                        if len(m) > 4:
                            self.results["passwords"].add(m.strip())
            except:
                pass
                
    def show_summary(self):
        self.log("\n" + "="*60)
        self.log("📊 SUMMARY OF FINDINGS")
        self.log("="*60)
        self.log(f"Open ports: {len(self.results['ports'])}")
        if self.results['ports']:
            for p in sorted(self.results['ports']):
                svc = self.results['services'].get(p, 'unknown')
                self.log(f"  {p}: {svc}")
        if self.results['web_techs']:
            self.log(f"Web technologies: {', '.join(sorted(self.results['web_techs'])[:5])}")
        if self.results['cms']:
            self.log(f"CMS: {self.results['cms']}")
        if self.results['directories']:
            self.log(f"Directories: {', '.join(sorted(self.results['directories'])[:5])}")
        if self.results['usernames']:
            self.log(f"Usernames: {', '.join(sorted(self.results['usernames']))}")
        if self.results['passwords']:
            self.log(f"Passwords/Hashes: {', '.join(sorted(self.results['passwords']))}")
        if self.results['flags']:
            self.log(f"Flags: {', '.join(sorted(self.results['flags']))}")
        if self.results['answers']:
            self.log(f"Answers: {', '.join(self.results['answers'])}")
        self.log("="*60)
        
    def start_attack(self):
        ip = self.ip_entry.get().strip()
        if not ip:
            messagebox.showerror("Error", "Please enter target IP")
            return
        self.current_ip = ip
        self.results = self.reset_results()
        self.results["ip"] = ip
        self.start_btn.config(state=tk.DISABLED, text="⚔️ ATTACKING...")
        self.log(f"\n{'='*60}")
        self.log(f"🎯 TARGET: {ip}")
        self.log("="*60)
        
        self.attack_thread = threading.Thread(target=self.run_attack, args=(ip,))
        self.attack_thread.daemon = True
        self.attack_thread.start()
        
    def run_attack(self, ip):
        try:
            # 1. nmap سريع
            self.log("[1] 🔍 Running quick nmap scan...")
            out = self.run_cmd(f"nmap -F -sV -T4 {ip}", timeout=300)
            if out:
                for line in out.split('\n'):
                    m = re.search(r'(\d+)/tcp\s+open\s+(\S+)', line)
                    if m:
                        port, svc = int(m.group(1)), m.group(2)
                        self.results["ports"].append(port)
                        self.results["services"][port] = svc
                        self.log(f"    🔓 Port {port}: {svc}")
            if not self.results["ports"]:
                self.log("    ⚠️ No open ports found, trying full scan...")
                out = self.run_cmd(f"nmap -p- -T4 {ip}", timeout=600)
                if out:
                    for line in out.split('\n'):
                        m = re.search(r'(\d+)/tcp\s+open', line)
                        if m:
                            port = int(m.group(1))
                            self.results["ports"].append(port)
                            self.results["services"][port] = "unknown"
                            self.log(f"    🔓 Port {port}: unknown")
                            
            if not self.results["ports"]:
                self.log("❌ No open ports found. Target may be down.")
                self.finish_attack()
                return
                
            # 2. محاولة التعرف على الغرفة
            room_id = self.identify_room()
            if room_id:
                self.display_room_answers(room_id)
                self.finish_attack()
                return
            else:
                self.log("\n⚠️ Room not in database. Starting deep reconnaissance...")
                
            # 3. فحص الويب
            web_ports = [p for p in self.results["ports"] if p in [80,443,8080,8443,8000,8888] or 'http' in self.results["services"].get(p,'')]
            if web_ports:
                self.log("[2] 🌐 Scanning web services...")
                for port in web_ports:
                    self.scan_web(ip, port)
                    
            # 4. فحص الخدمات الأخرى
            self.log("[3] 📡 Enumerating services...")
            self.scan_ftp(ip)
            self.scan_smb(ip)
            self.scan_ssh(ip)
            
            # 5. البحث عن الأعلام
            if web_ports:
                self.log("[4] 🎯 Hunting for flags...")
                self.hunt_flags(ip, web_ports)
                
            # 6. استخراج المعلومات
            self.log("[5] 📋 Extracting info from outputs...")
            self.extract_info()
            
            # 7. عرض الملخص
            self.show_summary()
            
        except Exception as e:
            self.log(f"❌ Error: {e}")
        finally:
            self.finish_attack()
            
    def finish_attack(self):
        self.root.after(0, lambda: self.start_btn.config(state=tk.NORMAL, text="🚀 START ATTACK"))
        self.save_results()

def main():
    root = tk.Tk()
    app = GhenaSmartSolver(root)
    root.mainloop()

if __name__ == "__main__":
    main()
