def run_command(cmd, timeout=120, show_output=True):
    """تنفيذ أمر وعرضه"""
    if show_output:
        print(f"  {KALI_CYAN}▶{KALI_END} {cmd}")
    try:
        result = subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT,
                                       text=True, timeout=timeout)
        return result
    except subprocess.TimeoutExpired:
        print_warning(f"Command timed out: {cmd[:50]}...")
    except subprocess.CalledProcessError as e:
        print_warning(f"Command failed (code {e.returncode})")
    except Exception as e:
        print_error(f"Error: {e}")
    return ""

def animate_progress(duration=2, message="Scanning"):
    """عرض شريط تقدم متحرك"""
    chars = "█▓▒░"
    for i in range(20):
        percent = (i+1)*5
        bar = chars[i%4] * (i+1) + " " * (19-i)
        sys.stdout.write(f"\r  {KALI_GREEN}[{bar}]{KALI_END} {message} {percent}%")
        sys.stdout.flush()
        time.sleep(duration/20)
    print()

# ======================= الفئة الرئيسية =======================
class GhenaKali:
    def __init__(self, target_ip):
        self.ip = target_ip
        self.results = {
            "ports": [],
            "services": {},
            "web_techs": set(),
            "directories": set(),
            "cms": None,
            "title": None,
            "usernames": set(),
            "passwords": set(),
            "hashes": set(),
            "flags": set(),
            "answers": [],
            "vulnerabilities": set()
        }
        self.start_time = datetime.now()
        self.session_dir = Path(f"GHENA_{target_ip}_{int(time.time())}")
        self.session_dir.mkdir(exist_ok=True)
        self.load_db()

    def load_db(self):
        """تحميل قاعدة البيانات"""
        if DB_PATH.exists():
            with open(DB_PATH, 'r', encoding='utf-8') as f:
                self.rooms_db = json.load(f)
        else:
            with open(DB_PATH, 'w', encoding='utf-8') as f:
                json.dump(KALI_ROOMS, f, indent=4)
            self.rooms_db = KALI_ROOMS

    def get_web_title(self, port):
        protocol = 'https' if port in [443,8443] else 'http'
        out = run_command(f"curl -s {protocol}://{self.ip}:{port} | grep -i '<title>' | head -1", show_output=False)
        if out:
            match = re.search(r'<title>(.*?)</title>', out, re.IGNORECASE)
            if match:
                return match.group(1).strip()
        return None

    def get_cms(self, port):
        protocol = 'https' if port in [443,8443] else 'http'
        out = run_command(f"whatweb {protocol}://{self.ip}:{port} --log-verbose=/dev/null", show_output=False)
        if out:
            cms_list = ['WordPress', 'Joomla', 'Drupal', 'Magento', 'Simple Image Gallery', 'CMS Made Simple', 'Bolt']
            for cms in cms_list:
                if cms.lower() in out.lower():
                    return cms
        return None

    def scan_web(self, port):
        protocol = 'https' if port in [443,8443] else 'http'
        print_info(f"Scanning web on port {port}...")

        # whatweb
        out = run_command(f"whatweb {protocol}://{self.ip}:{port} --log-verbose=/dev/null")
        if out:
            techs = re.findall(r'([A-Za-z0-9]+(?:-[A-Za-z0-9]+)*)\[', out)
            for t in techs:
                self.results["web_techs"].add(t)

        # gobuster
        out = run_command(f"gobuster dir -u {protocol}://{self.ip}:{port} -w /usr/share/wordlists/dirb/common.txt -t 50 -q")
        if out:
            dirs = re.findall(r'/(\S+)\s+\(Status: 200\)', out)
            for d in dirs:
                self.results["directories"].add(d)

        # title & cms
        title = self.get_web_title(port)
        if title:
            self.results["title"] = title
            print_success(f"Page title: {title}")

        cms = self.get_cms(port)
        if cms:
            self.results["cms"] = cms
            print_success(f"CMS detected: {cms}")

    def scan_ftp(self):
        if 21 not in self.results["ports"]:
            return
        print_info("Checking FTP...")
        out = run_command(f"nmap --script ftp-anon -p 21 {self.ip}")
        if "Anonymous FTP login allowed" in out:
            print_success("FTP anonymous login allowed")
            ftp_out = run_command(f"echo -e 'anonymous\\n\\nls\\nbye' | ftp -n {self.ip} 2>/dev/null")
            files = re.findall(r'^-rw-r--r--.*?(\S+)$', ftp_out, re.MULTILINE)
            if files:
                print_info(f"Files: {', '.join(files)}")

    def scan_smb(self):
        if any(p in [139,445] for p in self.results["ports"]):
            print_info("Checking SMB...")
            out = run_command(f"enum4linux -a {self.ip}")
            if out:
                users = re.findall(r'user:\[(\S+)\]', out)
                for u in users:
                    self.results["usernames"].add(u)
                if users:
                    print_success(f"SMB users: {', '.join(users)}")

    def scan_ssh(self):
        if 22 in self.results["ports"]:
            print_info("Checking SSH...")
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(5)
                sock.connect((self.ip, 22))
                banner = sock.recv(1024).decode()
                sock.close()
                print_success(f"SSH Banner: {banner.strip()}")
            except:
                pass

    def hunt_flags(self, web_ports):
        print_info("Hunting for flags...")
        flag_paths = [
            "/flag.txt", "/root/flag.txt", "/root/root.txt", "/root.txt",
            "/home/*/flag.txt", "/home/*/user.txt", "/user.txt",
            "/var/www/flag.txt", "/tmp/flag.txt", "/.flag", "/secret.txt"
        ]
        found = 0
        for port in web_ports:
            protocol = 'https' if port in [443,8443] else 'http'
            for path in flag_paths:
                out = run_command(f"curl -s {protocol}://{self.ip}:{port}{path}", show_output=False)
                if out and len(out) < 500:
                    patterns = [r'THM\{[^}]+\}', r'flag\{[^}]+\}', r'FLAG\{[^}]+\}']
                    for pat in patterns:
                        matches = re.findall(pat, out)
                        for m in matches:
                            if m not in self.results["flags"]:
                                self.results["flags"].add(m)
                                print_success(f"Flag found at {path}: {m}")
                                found += 1
        if found == 0:
            print_warning("No flags found in common locations.")

    def identify_room(self):
        """التعرف على الغرفة باستخدام المنافذ والمعلومات"""
        ports_set = set(self.results["ports"])
        best_match = None
        best_score = 0
        for room_id, data in self.rooms_db.items():
            known_ports = set(data.get("ports", []))
            if not known_ports:
                continue
            score = len(ports_set.intersection(known_ports))
            if score > best_score:
                best_score = score
                best_match = room_id
        if best_match and best_score >= len(self.rooms_db[best_match]["ports"]) * 0.6:
            return best_match
        return None

    def run(self):
        print_banner()
        print(f"{KALI_PURPLE}[>]{KALI_END} Target: {KALI_BOLD}{self.ip}{KALI_END}")
        print(f"{KALI_PURPLE}[>]{KALI_END} Started at: {self.start_time.strftime('%Y-%m-%d %H:%M:%S')}")
        print(f"{KALI_PURPLE}[>]{KALI_END} Session directory: {self.session_dir}\n")

        # 1. Nmap scan
        print_step(1, "RECONNAISSANCE - Port scanning")
        animate_progress(2, "Scanning ports")
        out = run_command(f"nmap -F -sV -T4 {self.ip}", timeout=300)
        if out:
            for line in out.split('\n'):
                m = re.search(r'(\d+)/tcp\s+open\s+(\S+)', line)
                if m:
                    port, svc = int(m.group(1)), m.group(2)
                    self.results["ports"].append(port)
                    self.results["services"][port] = svc
                    print_success(f"Port {port}: {svc}")
        if not self.results["ports"]:
            print_warning("No open ports found. Trying full scan...")
            out = run_command(f"nmap -p- -T4 {self.ip}", timeout=600)
            if out:
                for line in out.split('\n'):
                    m = re.search(r'(\d+)/tcp\s+open', line)
                    if m:
                        port = int(m.group(1))
                        self.results["ports"].append(port)
                        self.results["services"][port] = "unknown"
                        print_success(f"Port {port}: unknown")

        if not self.results["ports"]:
            print_error("No open ports found. Target may be down.")
            return

        # 2. Web enumeration
        web_ports = [p for p in self.results["ports"] if p in [80,443,8080,8443,8000,8888] or 'http' in self.results["services"].get(p,'')]
        if web_ports:
            print_step(2, "WEB ENUMERATION - Analyzing web services")
            for port in web_ports:
                self.scan_web(port)

        # 3. Room identification
        print_step(3, "ROOM IDENTIFICATION")
        room_id = self.identify_room()
        if room_id:
            data = self.rooms_db[room_id]
            print_success(f"Room identified: {data['name']}")
            # عرض الثغرات
            if data.get('vulnerabilities'):
                print_info("Vulnerabilities:")
                for v in data['vulnerabilities']:
                    print(f"    - {v}")
                    self.results['vulnerabilities'].add(v)
            # عرض الإجابات
            if data.get('answers'):
                print_info("CTF Answers:")
                for ans in data['answers']:
                    print(f"    {KALI_GREEN}•{KALI_END} {ans}")
                    self.results['answers'].append(ans)
        else:
            print_warning("Room not in database. Performing deep enumeration...")

        # 4. Service enumeration
        print_step(4, "SERVICE ENUMERATION")
        with ThreadPoolExecutor(max_workers=3) as executor:
            executor.submit(self.scan_ftp)
            executor.submit(self.scan_smb)
            executor.submit(self.scan_ssh)

        # 5. Flag hunting
        if web_ports:
            print_step(5, "FLAG HUNTING")
            self.hunt_flags(web_ports)

        # 6. Generate report
        print_step(6, "GENERATING REPORT")
        self.generate_report()

    def generate_report(self):
        """إنشاء تقرير وحفظه"""
        elapsed = (datetime.now() - self.start_time).total_seconds()
        report_file = self.session_dir / "report.txt"
        with open(report_file, 'w') as f:
            f.write("="*60 + "\n")
            f.write("GHENA KALI EDITION - ATTACK REPORT\n")
            f.write(f"Target: {self.ip}\n")
            f.write(f"Date: {self.start_time.strftime('%Y-%m-%d %H:%M:%S')}\n")
            f.write(f"Duration: {elapsed:.2f} seconds\n")
            f.write("="*60 + "\n\n")

            f.write("OPEN PORTS:\n")
            for p in sorted(self.results['ports']):
                svc = self.results['services'].get(p, 'unknown')
                f.write(f"  {p}: {svc}\n")
            f.write("\n")

            if self.results['web_techs']:
                f.write("WEB TECHNOLOGIES:\n")
                for t in sorted(self.results['web_techs']):
                    f.write(f"  {t}\n")
                f.write("\n")

            if self.results['directories']:
                f.write("DIRECTORIES:\n")
                for d in sorted(self.results['directories']):
                    f.write(f"  /{d}\n")
                f.write("\n")

            if self.results['cms']:
                f.write(f"CMS: {self.results['cms']}\n\n")

            if self.results['title']:
                f.write(f"PAGE TITLE: {self.results['title']}\n\n")

            if self.results['usernames']:
                f.write("USERNAMES:\n")
                for u in sorted(self.results['usernames']):
                    f.write(f"  {u}\n")
                f.write("\n")

            if self.results['passwords']:
                f.write("PASSWORDS/HASHES:\n")
                for p in sorted(self.results['passwords']):
                    f.write(f"  {p}\n")
                f.write("\n")

            if self.results['flags']:
                f.write("FLAGS:\n")
                for fl in sorted(self.results['flags']):
                    f.write(f"  {fl}\n")
                f.write("\n")

            if self.results['vulnerabilities']:
                f.write("VULNERABILITIES:\n")
                for v in sorted(self.results['vulnerabilities']):
                    f.write(f"  {v}\n")
                f.write("\n")

            if self.results['answers']:
                f.write("CTF ANSWERS:\n")
                for a in self.results['answers']:
                    f.write(f"  {a}\n")

        print_success(f"Report saved to {report_file}")
        print(f"{KALI_CYAN}[{KALI_BOLD}✓{KALI_END}{KALI_CYAN}]{KALI_END} Attack completed in {elapsed:.2f} seconds.")

