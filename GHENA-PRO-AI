#!/usr/bin/env python3
import subprocess
import shlex
import re
import datetime
import requests

# ========= UI =========
G="\033[92m"; Y="\033[93m"; C="\033[96m"; R="\033[91m"; END="\033[0m"

notes = []

# ========= RUNNER =========
def run(cmd):
    print(f"{Y}[RUN]{END} {cmd}")
    try:
        p = subprocess.Popen(
            shlex.split(cmd),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True
        )
        out, err = p.communicate(timeout=120)
        return out if out else err
    except Exception as e:
        return str(e)

# ========= PARSER =========
def parse_nmap(data):
    return re.findall(r'(\d+)/tcp\s+open\s+([^\s]+)', data)

# ========= ROOM CLASSIFIER =========
def classify_room(name, services):
    s = set(services)

    if "ftp" in s and "ssh" in s:
        return "Linux Credential Box"
    if "http" in s and "login" in name.lower():
        return "Web Authentication / Hijack Box"
    if "http" in s:
        return "Web Exploitation Box"
    if "nfs" in s:
        return "File Share Exploitation Box"
    if "ftp" in s:
        return "FTP Misconfiguration Box"

    return "Unknown Mixed Box"

# ========= WEB CHECK =========
def web_check(target):
    try:
        r = requests.get(f"http://{target}", timeout=5)
        t = r.text.lower()

        if "login" in t:
            return "Login panel detected"
        if "upload" in t:
            return "File upload feature detected"
        if "dashboard" in t:
            return "Authenticated panel detected"
        if "?id=" in t:
            return "Possible IDOR / SQL injection parameter"

        return "No obvious web vectors"

    except:
        return "Web unreachable"

# ========= EXPLOIT HINT ENGINE =========
def exploit_hints(services):
    hints = []

    if "ftp" in services:
        hints.append("FTP → check anonymous login + file enumeration")

    if "http" in services:
        hints.append("Web → check login, sessions, cookies, hidden dirs")

    if "ssh" in services:
        hints.append("SSH → reuse credentials or brute force weak users")

    if "nfs" in services:
        hints.append("NFS → mount shares and search sensitive files")

    if "rpcbind" in services:
        hints.append("RPC → enumerate services (rpcinfo -p)")

    return hints

# ========= ATTACK PATH GENERATOR =========
def attack_path(services):
    path = []

    if "http" in services:
        path.append("1. Web enumeration (directories, login, parameters)")
        path.append("2. Test session handling / auth bypass")

    if "ftp" in services:
        path.append("3. FTP access → extract files / credentials")

    if "nfs" in services:
        path.append("4. Mount NFS share → search secrets")

    if "ssh" in services:
        path.append("5. SSH login using discovered credentials")

    path.append("6. Privilege escalation (sudo / SUID / cron / kernel)")

    return path

# ========= ROOM INTELLIGENCE (NEW CORE) =========
