        self.start_btn = tk.Button(input_frame, text="🚀 START ATTACK",
                                    font=("Arial", 12, "bold"),
                                    bg=GREEN, fg=BLACK, command=self.start_attack)
        self.start_btn.pack(side=tk.LEFT, padx=10)
        
        output_frame = tk.Frame(self.root, bg=BLACK)
        output_frame.pack(fill=tk.BOTH, expand=True, padx=20, pady=10)
        
        self.output_text = scrolledtext.ScrolledText(output_frame, wrap=tk.WORD,
                                                      font=("Courier", 10),
                                                      bg=BLACK, fg=GREEN,
                                                      insertbackground=GREEN)
        self.output_text.pack(fill=tk.BOTH, expand=True)
        
        bottom_frame = tk.Frame(self.root, bg=BLACK)
        bottom_frame.pack(pady=10)
        
        self.clear_btn = tk.Button(bottom_frame, text="🧹 CLEAR",
                                    font=("Arial", 10),
                                    bg=DARK_GREEN, fg=WHITE, command=self.clear_output)
        self.clear_btn.pack(side=tk.LEFT, padx=5)
        
        self.save_btn = tk.Button(bottom_frame, text="💾 SAVE RESULTS",
                                   font=("Arial", 10),
                                   bg=DARK_GREEN, fg=WHITE, command=self.save_results)
        self.save_btn.pack(side=tk.LEFT, padx=5)
        
        self.exit_btn = tk.Button(bottom_frame, text="❌ EXIT",
                                   font=("Arial", 10),
                                   bg=DARK_GREEN, fg=WHITE, command=self.root.quit)
        self.exit_btn.pack(side=tk.LEFT, padx=5)
        
        self.log(f"✅ GHENA SMART loaded with {len(self.rooms_db)} rooms in DB.")
