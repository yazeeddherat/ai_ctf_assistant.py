    def log(self, message, color=GREEN):
        timestamp = datetime.now().strftime("%H:%M:%S")
        self.output_queue.put(f"[{timestamp}] {message}\n")
        
    def update_output(self):
        try:
            while True:
                msg = self.output_queue.get_nowait()
                self.output_text.insert(tk.END, msg)
                self.output_text.see(tk.END)
        except queue.Empty:
            pass
        self.root.after(100, self.update_output)
        
    def clear_output(self):
        self.output_text.delete(1.0, tk.END)
        
    def save_results(self):
        if not self.current_ip:
            messagebox.showwarning("Warning", "No results to save yet.")
            return
            
        filename = f"GHENA58_{self.current_ip}_{int(time.time())}.txt"
        try:
            with open(filename, 'w', encoding='utf-8') as f:
                f.write("="*60 + "\n")
                f.write("GHENA 58 EASY CTF SOLVER - RESULTS\n")
                f.write(f"Target IP: {self.current_ip}\n")
                f.write(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
                f.write("="*60 + "\n\n")
                
                f.write(f"Open Ports ({len(self.results['ports'])}):\n")
                for p in sorted(self.results['ports']):
                    svc = self.results['services'].get(p, 'unknown')
                    f.write(f"  {p}: {svc}\n")
                f.write("\n")
                
                if self.results['cms']:
                    f.write(f"CMS: {self.results['cms']}\n\n")
                    
                if self.results['usernames']:
                    f.write("Usernames found:\n")
                    for u in sorted(self.results['usernames']):
                        f.write(f"  {u}\n")
                    f.write("\n")
                    
                if self.results['passwords']:
                    f.write("Passwords/Hashes found:\n")
                    for p in sorted(self.results['passwords']):
                        f.write(f"  {p}\n")
                    f.write("\n")
                    
                if self.results['hashes']:
                    f.write("Hashes found:\n")
                    for h in sorted(self.results['hashes']):
                        f.write(f"  {h}\n")
                    f.write("\n")
                    
                if self.results['flags']:
                    f.write("Flags found:\n")
                    for fl in sorted(self.results['flags']):
                        f.write(f"  {fl}\n")
                    f.write("\n")
                    
                if self.results['answers']:
                    f.write("Answers to questions:\n")
                    for ans in self.results['answers']:
                        f.write(f"  {ans}\n")
                        
            messagebox.showinfo("Success", f"Results saved to {filename}")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to save: {e}")
            
    def run_cmd(self, cmd, timeout=120):
        try:
            result = subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT,
                                           text=True, timeout=timeout)
            return result
        except subprocess.TimeoutExpired:
            self.log(f"    ⏰ Command timed out: {cmd[:50]}...")
        except subprocess.CalledProcessError as e:
            self.log(f"    ⚠️ Command failed (code {e.returncode}): {cmd[:50]}...")
        except Exception as e:
            self.log(f"    ❌ Error: {e}")
        return ""
        
    def parse_nmap_output(self, output):
        for line in output.split('\n'):
            m = re.search(r'(\d+)/tcp\s+open\s+(\S+)', line)
            if m:
                port, svc = int(m.group(1)), m.group(2)
                if port not in self.results["ports"]:
                    self.results["ports"].append(port)
                    self.results["services"][port] = svc
                    self.log(f"    🔓 Port {port}: {svc}")
                    
    def identify_easy_room(self):
        ports_set = set(self.results["ports"])
        best_match = None
        best_score = 0
        
        for room_id, data in EASY_ROOMS_DB.items():
            known_ports = set(data.get("ports", []))
            if not known_ports:
                continue
            score = len(ports_set.intersection(known_ports))
            if score > best_score:
                best_score = score
                best_match = room_id
                
        if best_match and best_score >= len(EASY_ROOMS_DB[best_match]["ports"]) * 0.6:
            self.log(f"\n✅ Room identified: {EASY_ROOMS_DB[best_match].get('name', best_match)}")
            return best_match
        return None
        
    def display_room_answers(self, room_id):
        data = EASY_ROOMS_DB[room_id]
        self.log("\n" + "="*60)
        self.log(f"🎯 ROOM: {data.get('name', room_id)} (Easy)")
        self.log("="*60)
        
        if "answers" in data and data["answers"]:
            self.results["answers"] = data["answers"]
            for ans in data["answers"]:
                self.log(f"  ✅ {ans}")
        else:
            self.log("  No predefined answers for this room.")
            
        if "user_flag" in data:
            self.results["flags"].add(data["user_flag"])
        if "root_flag" in data:
            self.results["flags"].add(data["root_flag"])
        if "password" in data:
            self.results["passwords"].add(data["password"])
        if "hash" in data:
            self.results["hashes"].add(data["hash"])
        if "usernames" in data:
            for u in data["usernames"]:
                self.results["usernames"].add(u)
                
    def start_attack(self):
        ip = self.ip_entry.get().strip()
        if not ip:
            messagebox.showerror("Error", "Please enter target IP")
            return
            
        self.current_ip = ip
        self.results = self.reset_results()
        self.results["ip"] = ip
        self.start_btn.config(state=tk.DISABLED, text="⚔️ ATTACKING...")
        self.log(f"\n{'='*60}")
        self.log(f"🎯 TARGET: {ip}")
        self.log(f"{'='*60}\n")
        
        self.attack_thread = threading.Thread(target=self.run_attack, args=(ip,))
        self.attack_thread.daemon = True
        self.attack_thread.start()
        
    def run_attack(self, ip):
        try:
            # 1. nmap سريع
            self.log("[1] 🔍 Running quick nmap scan (top 1000 ports)...")
            output = self.run_cmd(f"nmap -F -sV -T4 {ip}", timeout=300)
            if output:
                self.parse_nmap_output(output)
            else:
                self.log("    ⚠️ Quick scan failed, trying full port scan...")
                output = self.run_cmd(f"nmap -p- -T4 {ip}", timeout=600)
                if output:
                    self.parse_nmap_output(output)
                    
            if not self.results["ports"]:
                self.log("    ❌ No open ports found. Target may be down.")
                self.finish_attack()
                return
                
            # 2. محاولة التعرف على الغرفة
            room = self.identify_easy_room()
            if room:
                self.display_room_answers(room)
                self.finish_attack()
                return
            else:
                self.log("    ⚠️ Room not recognized in database.")
                
        except Exception as e:
            self.log(f"❌ Error during attack: {e}")
        finally:
            self.finish_attack()
            
    def finish_attack(self):
        self.root.after(0, lambda: self.start_btn.config(state=tk.NORMAL, text="🚀 START ATTACK"))
        self.save_results()

