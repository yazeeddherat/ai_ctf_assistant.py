# ======================= محرك القواعد =======================
class RuleEngine:
    def __init__(self, target_ip: str):
        self.ip = target_ip
        self.open_ports = []
        self.services = {}
        self.versions = {}
        self.executed = []
        
        self.rules = [
            {
                "name": "nmap_initial",
                "condition": lambda ctx: len(ctx.open_ports) == 0,
                "command": "nmap -sV -T4 {ip}",
                "reason": "بدء استكشاف الهدف",
                "priority": 100
            },
            {
                "name": "web_scan",
                "condition": lambda ctx: any(p in [80, 443, 8080] for p in ctx.open_ports),
                "command": "gobuster dir -u http://{ip}:{port} -w /usr/share/wordlists/dirb/common.txt -t 50",
                "reason": "فحص الدلائل على الويب",
                "priority": 80,
                "port_dependent": True
            },
            {
                "name": "smb_enum",
                "condition": lambda ctx: any(p in [139, 445] for p in ctx.open_ports),
                "command": "enum4linux -a {ip}",
                "reason": "جمع معلومات SMB",
                "priority": 85
            }
        ]
        
    def update_context(self, open_ports, services, versions, executed):
        self.open_ports = open_ports
        self.services = services
        self.versions = versions
        self.executed = executed
        
    def get_next_commands(self):
        candidates = []
        for rule in self.rules:
            try:
                if rule.get("port_dependent"):
                    for port in self.open_ports:
                        cmd = rule["command"].format(ip=self.ip, port=port)
                        candidates.append({
                            "cmd": cmd,
                            "reason": rule["reason"],
                            "priority": rule["priority"]
                        })
                else:
                    if rule["condition"](self):
                        cmd = rule["command"].format(ip=self.ip)
                        candidates.append({
                            "cmd": cmd,
                            "reason": rule["reason"],
                            "priority": rule["priority"]
                        })
            except:
                continue
        candidates.sort(key=lambda x: x["priority"], reverse=True)
        return candidates

# ======================= العقل المدبر =======================
class GhenaCore:
    def __init__(self, target_ip: str, goal: str = "user_flag"):
        self.ip = target_ip
        self.goal = goal
        self.engine = RuleEngine(target_ip)
        self.history = []
        self.findings = []
        self.open_ports = []
        self.services = {}
        self.versions = {}
        self.executed = []
        self.stop = False
        
        # إنشاء مجلد للجلسة
        self.session_dir = Path(f"GHENA_{target_ip}_{int(time.time())}")
        self.session_dir.mkdir(exist_ok=True)
        
    def log(self, msg, level="info"):
        timestamp = datetime.now().strftime("%H:%M:%S")
        color = COLORS.get(level.upper(), COLORS["OKBLUE"])
        print(f"{color}[{timestamp}] {msg}{COLORS['ENDC']}")
        
    def is_safe(self, cmd):
        cmd_lower = cmd.lower()
        for pattern in BLOCKED_PATTERNS:
            if pattern in cmd_lower:
                return False
        first = cmd_lower.split()[0] if cmd_lower else ""
        return first in ALLOWED_COMMANDS
        
    def execute(self, cmd, timeout=600):
        self.log(f"⚡ تنفيذ: {cmd}", "command")
        
        if not self.is_safe(cmd):
            self.log("⚠️ أمر غير آمن - تم الرفض", "warning")
            return "REJECTED"
            
        try:
            result = subprocess.check_output(
                cmd, shell=True, stderr=subprocess.STDOUT,
                text=True, timeout=timeout
            )
            self.executed.append(cmd)
            self.history.append({
                "cmd": cmd,
                "result": result[:500],
                "time": datetime.now().isoformat()
            })
            self.analyze(result, cmd)
            return result
        except Exception as e:
            self.log(f"❌ خطأ: {e}", "error")
            return str(e)
            
    def analyze(self, output, cmd):
        # استخراج المنافذ من nmap
        if "nmap" in cmd:
            pattern = r"(\d+)/tcp\s+open\s+(\S+)"
            for port, service in re.findall(pattern, output):
                port = int(port)
                if port not in self.open_ports:
                    self.open_ports.append(port)
                    self.services[port] = service
                    self.log(f"🔓 منفذ جديد: {port} ({service})", "critical")
                    
        # البحث عن العلم
        flag_pattern = r"flag\{[^}]+\}|FLAG\{[^}]+\}"
        match = re.search(flag_pattern, output)
        if match:
            self.findings.append({
                "severity": "CRITICAL",
                "title": "🎯 تم العثور على العلم!",
                "flag": match.group(0),
                "command": cmd
            })
            self.log(f"🎉 العلم: {match.group(0)}", "critical")
            self.stop = True
            
        # البحث عن صلاحيات الجذر
        if re.search(r"# |root:", output):
            self.findings.append({
                "severity": "CRITICAL",
                "title": "🔓 صلاحيات الجذر!",
                "command": cmd
            })
            self.log("🔓 تم الوصول إلى الجذر!", "critical")
            self.stop = True
            
    def save_state(self):
        state = {
            "ip": self.ip,
            "goal": self.goal,
            "open_ports": self.open_ports,
            "services": self.services,
            "findings": self.findings,
            "history": self.history,
            "time": datetime.now().isoformat()
        }
        with open(self.session_dir / "state.json", "w") as f:
            json.dump(state, f, indent=2)
        self.log("💾 تم حفظ الحالة")
        
    def run(self):
        self.log("🚀 بدء الهجوم...", "header")
        
        commands = self.engine.get_next_commands()
        
        while commands and not self.stop:
            for cmd_info in commands:
                if self.stop:
                    break
                    
                print(f"\n{COLORS['OKCYAN']}📋 {cmd_info['reason']}{COLORS['ENDC']}")
                print(f"{COLORS['BOLD']}الأمر: {cmd_info['cmd']}{COLORS['ENDC']}")
                
                ans = input("تنفيذ؟ [Y/n] ").strip().lower()
                if ans in ('', 'y', 'yes'):
                    output = self.execute(cmd_info['cmd'])
                    print(output[:300] + ("..." if len(output) > 300 else ""))
                    
                # تحديث السياق
                self.engine.update_context(
                    self.open_ports, self.services,
                    self.versions, self.executed
                )
                self.save_state()
                
            commands = self.engine.get_next_commands()
            if not commands:
                self.log("✅ انتهت الأوامر", "success")
                
        self.generate_report()
        
    def generate_report(self):
        report = f"""
╔═══════════════════════════════════════════════════════════════╗
║                       تقرير الهجوم                           ║
╠═══════════════════════════════════════════════════════════════╣
║ الهدف: {self.ip}
║ المنافذ: {self.open_ports}
║ الخدمات: {self.services}
╠═══════════════════════════════════════════════════════════════╣
║ النتائج:
"""
        for f in self.findings:
            report += f"\n  🔹 {f['title']}"
            
        report += "\n╚═══════════════════════════════════════════════════════════════╝"
        
        print(report)
        with open(self.session_dir / "report.txt", "w") as f:
            f.write(report)

