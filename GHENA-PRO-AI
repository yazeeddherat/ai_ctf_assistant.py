    def start_attack(self):
        ip = self.ip_entry.get().strip()
        if not ip:
            messagebox.showerror("Error", "Please enter target IP")
            return
        self.current_ip = ip
        self.results = self.reset_results()
        self.results["ip"] = ip
        self.start_btn.config(state=tk.DISABLED, text="⚔️ ATTACKING...")
        self.log(f"\n{'='*60}")
        self.log(f"🎯 TARGET: {ip}")
        self.log('='*60)
        
        self.attack_thread = threading.Thread(target=self.run_attack, args=(ip,))
        self.attack_thread.daemon = True
        self.attack_thread.start()
        
    def run_attack(self, ip):
        try:
            # 1. nmap سريع
            self.step_title("1️⃣ فحص المنافذ (nmap)")
            out = self.run_cmd(f"nmap -F -sV -T4 {ip}", timeout=300)
            if out:
                for line in out.split('\n'):
                    m = re.search(r'(\d+)/tcp\s+open\s+(\S+)', line)
                    if m:
                        port, svc = int(m.group(1)), m.group(2)
                        self.results["ports"].append(port)
                        self.results["services"][port] = svc
                        self.success(f"المنفذ {port}: {svc}")
            if not self.results["ports"]:
                self.warning("لم يتم العثور على منافذ، جاري فحص كامل...")
                out = self.run_cmd(f"nmap -p- -T4 {ip}", timeout=600)
                if out:
                    for line in out.split('\n'):
                        m = re.search(r'(\d+)/tcp\s+open', line)
                        if m:
                            port = int(m.group(1))
                            self.results["ports"].append(port)
                            self.results["services"][port] = "unknown"
                            self.success(f"المنفذ {port}: unknown")
                            
            if not self.results["ports"]:
                self.warning("لا توجد منافذ مفتوحة. قد يكون الهدف مغلقاً.")
                self.finish_attack()
                return
                
            # 2. فحص الويب لجمع معلومات إضافية
            web_ports = [p for p in self.results["ports"] if p in [80,443,8080,8443,8000,8888] or 'http' in self.results["services"].get(p,'')]
            if web_ports:
                self.step_title("2️⃣ فحص الويب (whatweb + gobuster)")
                for port in web_ports[:1]:
                    self.scan_web(ip, port)
                    
            # 3. التعرف على الغرفة
            self.step_title("3️⃣ التعرف على الغرفة")
            room_id, match_percent = self.identify_room_precise()
            if room_id:
                self.display_room_answers(room_id, match_percent)
                self.info("سيتم إجراء فحص شامل للتأكد...")
            else:
                self.warning("الغرفة غير موجودة في قاعدة البيانات. بدء الفحص الشامل...")
                
            # 4. فحص شامل للخدمات الأخرى
            self.step_title("4️⃣ فحص شامل للخدمات")
            if web_ports:
                for port in web_ports[1:]:
                    self.scan_web(ip, port)
            self.scan_ftp(ip)
            self.scan_smb(ip)
            self.scan_ssh(ip)
            
            # 5. البحث عن الأعلام
            if web_ports:
                self.step_title("5️⃣ البحث عن الأعلام")
                self.hunt_flags(ip, web_ports)
                
            # 6. استخراج المعلومات
            self.step_title("6️⃣ استخراج المعلومات من الملفات")
            self.extract_info()
            
            # 7. الملخص النهائي
            self.step_title("7️⃣ الملخص النهائي")
            self.show_summary()
            
        except Exception as e:
            self.log(f"❌ خطأ: {e}")
        finally:
            self.finish_attack()
            
    def finish_attack(self):
        self.root.after(0, lambda: self.start_btn.config(state=tk.NORMAL, text="🚀 START ATTACK"))
        self.save_results()

def main():
    root = tk.Tk()
    app = GhenaDetailedSolver(root)
    root.mainloop()

if __name__ == "__main__":
    main()
