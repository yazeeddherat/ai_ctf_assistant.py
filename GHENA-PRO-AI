    def load_db(self):
        if DB_PATH.exists():
            with open(DB_PATH, 'r', encoding='utf-8') as f:
                return json.load(f)
        else:
            with open(DB_PATH, 'w', encoding='utf-8') as f:
                json.dump(DEFAULT_PRECISE_ROOMS, f, indent=4, ensure_ascii=False)
            return DEFAULT_PRECISE_ROOMS.copy()
            
