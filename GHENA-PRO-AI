# ── الـ Logic المتقدم للتحليل ──────────────────────────────────────

def analyze_nmap(output, ip):
    ports = re.findall(r'(\d+)/tcp\s+open\s+(\S+)', output)
    if not ports:
        pro_tip("Target is ghosting. Use -Pn and check for ICMP blocking.")
        return f"nmap -Pn -sS --min-rate 5000 {ip}", "Aggressive Stealth Scanning"

    found = [int(p[0]) for p in ports]
    print(f"\n{G}[+] Open Ports Identified: {W}{found}{END}")

    if 21 in found:
        pro_tip("FTP detected. 90% of CTFs have 'Anonymous' enabled or leak config files.")
        return f"nmap --script ftp-anon,ftp-libopie -p 21 {ip}", "Enumerating FTP Vulnerabilities"
    
    if 80 in found or 443 in found:
        pro_tip("Web server found. Time to bust directories and check for LFI/SQLi.")
        return f"ffuf -u http://{ip}/FUZZ -w /usr/share/wordlists/dirb/common.txt -t 60", "Fuzzing Web Directories"

    if 445 in found:
        pro_tip("SMB exposure. Check for 'Null Sessions' or 'EternalBlue'.")
        return f"enum4linux -a {ip}", "Full SMB Reconnaissance"

    return f"nmap -sV -sC -p {','.join(map(str, found))} {ip}", "Deep Service Fingerprinting"

def analyze_privesc(output):
    pro_tip("We are in. Now we need to escalate. Check GTFOBins for anything in Sudo.")
    if "ALL" in output.upper() and "NOPASSWD" in output.upper():
        print(f"{G}{BOLD}[!!!] CRITICAL: SUDO WITHOUT PASSWORD DETECTED!{END}")
        return "sudo su -", "Instant Root Shell Injection"
    
    if "docker" in output.lower():
        pro_tip("Container detected. Search for 'docker.sock' to escape to host.")
        return "find / -name docker.sock 2>/dev/null", "Locating Container Escape Vector"

    return "find / -perm -u=s -type f 2>/dev/null", "Searching for SUID Binaries"

