        subtitle.pack()
        
        input_frame = tk.Frame(self.root, bg=BLACK)
        input_frame.pack(pady=10)
        
        tk.Label(input_frame, text="Target IP:", font=("Arial", 12),
                 fg=WHITE, bg=BLACK).pack(side=tk.LEFT, padx=5)
        
