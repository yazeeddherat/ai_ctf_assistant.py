    # ========== التعرف على الغرفة ==========
    def identify_room_expert(self):
        """تحليل متقدم للتعرف على الغرفة مع تقييم ثغرات"""
        if not self.results["ports"]:
            return None, 0
            
        candidates = []
        for room_id, data in self.rooms_db.items():
            score = 0
            max_score = 0
            
            known_ports = set(data.get("ports", []))
            if known_ports:
                port_match = len(set(self.results["ports"]).intersection(known_ports))
                score += port_match * 10
                max_score += len(known_ports) * 10
                
            if "services" in data and self.results["services"]:
                for port, svc in self.results["services"].items():
                    if str(port) in data["services"] and data["services"][str(port)].split()[0].lower() in svc.lower():
                        score += 5
                        max_score += 5
                        
            if data.get("cms") and self.results["cms"] and data["cms"].lower() == self.results["cms"].lower():
                score += 20
                max_score += 20
                
            if data.get("title") and self.results["title"] and data["title"].lower() in self.results["title"].lower():
                score += 15
                max_score += 15
                
            if max_score > 0:
                match_percent = (score / max_score) * 100
                candidates.append((room_id, match_percent, data))
                
        candidates.sort(key=lambda x: x[1], reverse=True)
        
        if candidates and candidates[0][1] >= 70:
            best = candidates[0]
            self.expert_success(f"Room identified: {best[2].get('name')} with {best[1]:.1f}% confidence")
            
            # تحليل الخبرة
            analysis = f"Based on open ports and services, this matches {best[2].get('name')}.\n"
            analysis += f"Detected CMS: {self.results['cms']}\n"
            analysis += f"Page title: {self.results['title']}\n"
            analysis += f"Potential vulnerabilities: {', '.join(best[2].get('vulnerabilities', ['Unknown']))}"
            self.expert_analysis("Room Identification Analysis", analysis)
            
            # إضافة الثغرات
            for v in best[2].get('vulnerabilities', []):
                self.results['vulnerabilities'].add(v)
                
            return best[0], best[1]
        else:
            self.expert_warning("No exact match found in database. Performing full reconnaissance.")
            return None, 0
            
