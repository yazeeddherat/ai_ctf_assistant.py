    def update_context(self, services: Dict[int, str], open_ports: List[int], versions: Dict[str, str], discovered_paths: List[str], credentials: List[Tuple], executed: List[str]):
        self.services = services
        self.open_ports = open_ports
        self.software_versions = versions
        self.discovered_paths = discovered_paths
        self.credentials = credentials
        self.executed_commands = executed
        
    def get_next_commands(self) -> List[Dict]:
        """تقييم القواعد وإرجاع الأوامر المقترحة مرتبة حسب الأولوية"""
        candidates = []
        for rule in self.rules:
            try:
                if rule.get("port_dependent"):
                    for port in self.open_ports:
                        ctx = self  # سياق كامل
                        # نمرر المنفذ للقاعدة
                        cmd = rule["command"].format(ip=self.ip, port=port)
                        if not self._is_command_executed(cmd):
                            candidates.append({
                                "cmd": cmd,
                                "reason": rule["reason"].format(port=port),
                                "priority": rule["priority"],
                                "rule": rule["name"]
                            })
                elif rule.get("service_dependent"):
                    for service, version in self.software_versions.items():
                        cmd = rule["command"].format(ip=self.ip, service=service, version=version)
                        if not self._is_command_executed(cmd):
                            candidates.append({
                                "cmd": cmd,
                                "reason": rule["reason"].format(service=service, version=version),
                                "priority": rule["priority"],
                                "rule": rule["name"]
                            })
                else:
                    if rule["condition"](self):
                        cmd = rule["command"].format(ip=self.ip)
                        if not self._is_command_executed(cmd):
                            candidates.append({
                                "cmd": cmd,
                                "reason": rule["reason"],
                                "priority": rule["priority"],
                                "rule": rule["name"]
                            })
            except Exception as e:
                # تجاهل القاعدة إذا سببت خطأ
                continue
                
        # ترتيب حسب الأولوية (الأعلى أولاً)
        candidates.sort(key=lambda x: x["priority"], reverse=True)
        return candidates
        
    def _is_command_executed(self, cmd: str) -> bool:
        """التحقق مما إذا كان الأمر قد نُفذ من قبل (تقريباً)"""
        # تجاهل المتغيرات مثل {port} - نقارن بداية الأمر فقط
        base_cmd = cmd.split()[0] if cmd else ""
        return any(base_cmd in executed for executed in self.executed_commands)

# ======================= العقل المدبر (الرئيسي) =======================
class GhenaCore:
    """القلب النابض للأداة - يدير كل شيء"""
    
    def __init__(self, target_ip: str, goal: str = "user_flag"):
        self.ip = target_ip
        self.goal = goal
        self.rule_engine = RuleEngine(target_ip)
        self.history: List[Dict] = []
        self.findings: List[Dict] = []
        self.open_ports: List[int] = []
        self.services: Dict[int, str] = {}
        self.versions: Dict[str, str] = {}
        self.paths: List[str] = []
        self.credentials: List[Tuple[str, str]] = []
        self.executed_commands: List[str] = []
        self.stop_flag = False
        self.session_dir = Path(f"sessions/{target_ip}_{int(time.time())}")
        self.session_dir.mkdir(parents=True, exist_ok=True)
        
    def log(self, msg: str, level: str = "info"):
        timestamp = datetime.now().strftime("%H:%M:%S")
        color = COLORS.get(level.upper(), COLORS["OKBLUE"])
        print(f"{color}[{timestamp}] {msg}{COLORS['ENDC']}")
        
    def is_safe_command(self, cmd: str) -> Tuple[bool, str]:
        cmd_lower = cmd.lower()
        for pattern in BLOCKED_PATTERNS:
            if pattern in cmd_lower:
                return False, f"أمر محظور: {pattern}"
        first_word = cmd_lower.split()[0] if cmd_lower else ""
        if first_word and first_word not in ALLOWED_COMMANDS:
            if not any(cmd_lower.startswith(allowed) for allowed in ALLOWED_COMMANDS):
                return False, f"أداة غير مسموح بها: {first_word}"
        return True, "آمن"
        
    def execute_command(self, cmd: str, timeout: int = 600) -> str:
        self.log(f"تنفيذ: {cmd}", "command")
        safe, reason = self.is_safe_command(cmd)
        if not safe:
            self.log(f"تم رفض الأمر: {reason}", "warning")
            return f"REJECTED: {reason}"
            
        try:
            result = subprocess.check_output(cmd, shell=True, stderr=subprocess.STDOUT,
                                             text=True, timeout=timeout)
            self.executed_commands.append(cmd)
            self.history.append({
                "cmd": cmd,
                "result": result[:1000],  # حفظ جزء
                "time": datetime.now().isoformat()
            })
            self.analyze_output(result, cmd)
            return result
        except subprocess.TimeoutExpired:
            self.log("تجاوز الوقت المحدد", "error")
            return "TIMEOUT"
        except subprocess.CalledProcessError as e:
            self.log(f"خطأ: {e.output}", "error")
            return e.output
        except Exception as e:
            self.log(f"خطأ غير متوقع: {e}", "error")
            return f"ERROR: {e}"
            
    def analyze_output(self, output: str, cmd: str):
        """تحليل مخرجات الأوامر واستخراج المعلومات"""
        # كشف المنافذ الجديدة
        if "nmap" in cmd:
            self.extract_ports_from_nmap(output)
            self.extract_versions_from_nmap(output)
            
        # كشف المسارات من gobuster/dirb
        if "gobuster" in cmd or "dirb" in cmd:
            self.extract_paths_from_dirbuster(output)
            
        # كشف الثغرات المعروفة
        self.detect_vulnerabilities(output, cmd)
        
        # كشف العلم أو كلمات المرور
        self.detect_success_indicators(output, cmd)
        
    def extract_ports_from_nmap(self, output: str):
        pattern = r"(\d+)/tcp\s+open\s+(\S+)"
        matches = re.findall(pattern, output)
        for port_str, service in matches:
            port = int(port_str)
            if port not in self.open_ports:
                self.open_ports.append(port)
                self.services[port] = service
                self.log(f"🔓 منفذ جديد: {port} ({service})", "critical")
                
    def extract_versions_from_nmap(self, output: str):
        # محاولة استخراج الإصدارات من nmap
        pattern = r"(\d+)/tcp.*?(\S+)\s+(\d+\.\d+\.\d+|\d+\.\d+)"
        matches = re.findall(pattern, output)
        for port, service, version in matches:
            key = service.lower()
            self.versions[key] = version
            self.log(f"📌 {service} {version} على المنفذ {port}", "info")
            
            # البحث في قاعدة الثغرات
            vuln_key = f"{service.lower()} {version}"
            if vuln_key in VULNERABILITY_DB:
                vuln = VULNERABILITY_DB[vuln_key]
                self.findings.append({
                    "type": "vulnerability",
                    "severity": "CRITICAL" if vuln['cvss'] >= 9 else "HIGH",
                    "title": vuln['name'],
                    "description": vuln['description'],
                    "command": vuln['command'].format(ip=self.ip),
                    "cve": vuln['cve'],
                    "ref": vuln.get('ref', '')
                })
                self.log(f"🎯 ثغرة معروفة: {vuln['name']}", "critical")
                
    def extract_paths_from_dirbuster(self, output: str):
        # استخراج المسارات من gobuster/dirb
        pattern = r"(/\S+)\s+\(Status:\s*\d+\)"
        matches = re.findall(pattern, output)
        for path in matches:
            if path not in self.paths:
                self.paths.append(path)
                self.log(f"📁 مسار جديد: {path}", "success")
                
    def detect_vulnerabilities(self, output: str, cmd: str):
        # الكشف عن الثغرات بناءً على أنماط محددة
        vuln_patterns = {
            "root:|# ": "CRITICAL: يبدو أنك حصلت على صلاحيات الجذر!",
            "flag\{[^}]+\}": "🎯 العلم موجود!",
            "mysql_connect": "ربما هناك خطأ في اتصال MySQL",
            "SQL syntax": "قد يكون هناك ثغرة SQL injection",
            "Warning: include(": "ربما هناك LFI/RFI",
            "etc/passwd": "تم تسريب ملف passwd",
            "private key": "تم العثور على مفتاح خاص"
        }
        for pattern, msg in vuln_patterns.items():
            if re.search(pattern, output, re.IGNORECASE):
                finding = {
                    "type": "pattern",
                    "severity": "CRITICAL" if "🎯" in msg else "HIGH",
                    "title": msg,
                    "description": f"تم الكشف عن النمط '{pattern}' في مخرجات الأمر",
                    "command": cmd
                }
                self.findings.append(finding)
                self.log(msg, "critical")
                
    def detect_success_indicators(self, output: str, cmd: str):
        # البحث عن علامات النجاح بناءً على الهدف
        if self.goal == "user_flag":
            match = re.search(r"flag\{[^}]+\}", output)
            if match:
                self.findings.append({
                    "type": "flag",
                    "severity": "CRITICAL",
                    "title": "🎯 تم العثور على علم المستخدم!",
                    "flag": match.group(0),
                    "command": cmd
                })
                self.log(f"🎉 العلم: {match.group(0)}", "critical")
                self.stop_flag = True
        elif self.goal == "root_access":
            if re.search(r"# |root:", output):
                self.findings.append({
                    "type": "root",
                    "severity": "CRITICAL",
                    "title": "🔓 تم الوصول إلى صلاحيات الجذر!",
                    "command": cmd
                })
                self.log("🔓 تم الوصول إلى الجذر!", "critical")
                self.stop_flag = True
                
    def save_state(self):
        """حفظ الحالة الحالية للجلسة"""
        state = {
            "ip": self.ip,
            "goal": self.goal,
            "open_ports": self.open_ports,
            "services": self.services,
            "versions": self.versions,
            "paths": self.paths,
            "credentials": self.credentials,
            "history": self.history,
            "findings": self.findings,
            "timestamp": datetime.now().isoformat()
        }
        state_file = self.session_dir / "state.json"
        with open(state_file, "w") as f:
            json.dump(state, f, indent=2)
        self.log(f"💾 تم حفظ الحالة في {state_file}")
        
    def generate_report(self) -> str:
        """توليد تقرير نصي جميل"""
        report = f"""
╔═══════════════════════════════════════════════════════════════╗
║                       تقرير الهجوم                           ║
╠═══════════════════════════════════════════════════════════════╣
║ الهدف: {self.ip}
║ الهدف النهائي: {self.goal}
║ وقت البدء: {self.history[0]['time'] if self.history else 'N/A'}
║ عدد الخطوات: {len(self.history)}
╠═══════════════════════════════════════════════════════════════╣
║ المنافذ المفتوحة: {self.open_ports}
║ الخدمات المكتشفة: {json.dumps(self.services, indent=2, ensure_ascii=False)}
╠═══════════════════════════════════════════════════════════════╣
║ النتائج الهامة:
"""
        for finding in self.findings:
            report += f"""
  🔹 {finding.get('severity', 'INFO')}: {finding.get('title', '')}
     {finding.get('description', '')}
     الأمر: {finding.get('command', 'N/A')}
"""
        report += "╚═══════════════════════════════════════════════════════════════╝"
        return report
        
    def run_auto(self):
        """حلقة الهجوم الرئيسية"""
        self.log("🚀 بدء الهجوم التلقائي...", "header")
        
        # تنفيذ القاعدة الأولى (nmap)
        cmds = self.rule_engine.get_next_commands()
        while cmds and not self.stop_flag:
            for cmd_info in cmds:
                if self.stop_flag:
                    break
                cmd = cmd_info["cmd"]
                reason = cmd_info["reason"]
                self.log(f"📋 الاقتراح: {reason}", "info")
                self.log(f"الأمر: {cmd}", "command")
                
                # طلب موافقة المستخدم (في CLI)
                ans = input("هل تريد تنفيذ هذا الأمر؟ [Y/n] ").strip().lower()
                if ans in ('', 'y', 'yes'):
                    output = self.execute_command(cmd)
                    self.log(output[:500] + ("..." if len(output) > 500 else ""))
                else:
                    self.log("تم تخطي الأمر", "warning")
                
                # تحديث السياق بعد كل أمر
                self.rule_engine.update_context(
                    services=self.services,
                    open_ports=self.open_ports,
                    versions=self.versions,
                    discovered_paths=self.paths,
                    credentials=self.credentials,
                    executed=self.executed_commands
                )
                
                # حفظ الحالة بعد كل أمر
                self.save_state()
                
            # جلب الأوامر التالية
            cmds = self.rule_engine.get_next_commands()
            if not cmds:
                self.log("✅ لا توجد أوامر أخرى في القواعد.", "success")
                break
                
        self.log("🏁 انتهى الهجوم.", "header")
        report = self.generate_report()
        print(report)
        report_file = self.session_dir / "report.txt"
        with open(report_file, "w") as f:
            f.write(report)
        self.log(f"📄 تم حفظ التقرير في {report_file}")

