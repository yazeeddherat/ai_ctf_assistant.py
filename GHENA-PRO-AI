class AutonomousHealer:
    """وحدة متقدمة قادرة على تحليل مخرجات الخطأ وتعديل مسار الاختراق آلياً"""
    
    def __init__(self, target_ip):
        self.target = target_ip

    def resolve(self, cmd, stderr):
        err = stderr.lower()
        tool = cmd.split()[0]
        
        print(f"\n{Y}[!] تحليل العطل التكتيكي...{END}")

        # حالة 1: التعامل مع 404 (مشكلة Contrabando الأساسية)
        if "404" in err or "not found" in err:
            if tool in ["curl", "ffuf", "gobuster", "dirb"]:
                print(f"{G}[√] استراتيجية بديلة: تفعيل فحص الـ Virtual Hosts لتخطي الـ 404.{END}")
                return f"ffuf -u http://{self.target} -w /usr/share/wordlists/dirb/common.txt -H 'Host: FUZZ.contrabando.thm' -fs 0"

        # حالة 2: نقص الصلاحيات في Kali
        if "permission denied" in err or "root privileges" in err:
            print(f"{G}[√] استراتيجية بديلة: تصعيد الصلاحيات محلياً عبر Sudo.{END}")
            return f"sudo {cmd}"

        # حالة 3: الكشف عن جدار الحماية (WAF/Firewall)
        if "filtered" in err or "host seems down" in err:
            print(f"{G}[√] استراتيجية بديلة: استخدام الـ Fragmentation وتجاوز الـ ICMP.{END}")
            if "-Pn" not in cmd:
                return f"{cmd} -Pn -f -sS --min-rate 1000"

        # حالة 4: الأداة غير مثبتة
        if "not found" in err:
            print(f"{R}[!] الأداة مفقودة. جاري محاولة التثبيت من مستودعات Kali...{END}")
            os.system(f"sudo apt update && sudo apt install {tool} -y")
            return cmd

        return None

