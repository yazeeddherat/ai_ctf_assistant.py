        print(f"{BOLD}{CYAN}   📊 ملخص النتائج لـ {self.ip}{END}")
        print(f"{BOLD}{CYAN}{'='*60}{END}")

        print(f"\n{BOLD}المنافذ المفتوحة:{END} {GREEN}{len(self.results['ports'])}{END}")
        if self.results["ports"]:
            print(f"{BOLD}الخدمات:{END}")
            for p in sorted(self.results["ports"]):
                svc = self.results["services"].get(p, "unknown")
                print(f"  {p}: {svc}")

        if self.results["web_techs"]:
            print(f"\n{BOLD}تقنيات الويب:{END} {', '.join(set(self.results['web_techs']))}")

        if self.results["cms"]:
            print(f"\n{BOLD}نظام إدارة المحتوى (CMS):{END} {GREEN}{self.results['cms']}{END}")

        if self.results["directories"]:
            print(f"\n{BOLD}الدلائل المكتشفة:{END}")
            for d in sorted(set(self.results["directories"]))[:10]:
                print(f"  /{d}")

        if self.results["usernames"]:
            print(f"\n{BOLD}أسماء المستخدمين المحتملة:{END}")
            for u in sorted(self.results["usernames"]):
                print(f"  {u}")

        if self.results["passwords"]:
            print(f"\n{BOLD}كلمات المرور/الهاشات المحتملة:{END}")
            for p in sorted(self.results["passwords"])[:10]:
                print(f"  {p}")

        if self.results["flags"]:
            print(f"\n{BOLD}{GREEN}الأعلام المكتشفة:{END}")
            for f in sorted(self.results["flags"]):
                print(f"  {f}")

        print(f"\n{CYAN}{'='*60}{END}")
        self.log(f"✅ تم حفظ جميع المخرجات في {self.session_dir}", GREEN)

        # توليد إجابات محتملة للأسئلة الشائعة
        self.generate_possible_answers()

    def generate_possible_answers(self):
        """توليد إجابات محتملة للأسئلة الشائعة في THM"""
        print(f"\n{BOLD}{YELLOW}إجابات محتملة للأسئلة الشائعة:{END}")

        # كم عدد المنافذ المفتوحة؟
        print(f"  • عدد المنافذ المفتوحة: {len(self.results['ports'])}")

        # اسم CMS
        if self.results["cms"]:
            print(f"  • CMS: {self.results['cms']}")

        # الهاشات (قد تكون مطلوبة)
        if self.results["hashes"]:
            print(f"  • الهاشات:")
            for h in list(self.results["hashes"])[:3]:
                print(f"    - {h}")

        # الأعلام
        if self.results["flags"]:
            print(f"  • الأعلام:")
            for f in self.results["flags"]:
                print(f"    - {f}")

        # مستخدمون
        if self.results["usernames"]:
            print(f"  • المستخدمون: {', '.join(self.results['usernames'])}")

        # كلمات مرور
        if self.results["passwords"]:
            print(f"  • كلمات المرور: {', '.join(list(self.results['passwords'])[:5])}")

    # ==================== التشغيل الرئيسي ====================

    def run(self):
        self.log("="*60, CYAN)
        self.log(f"{BOLD}🚀 بدء الفحص الشامل لـ {self.ip} (جميع غرف THM){END}", CYAN)
        self.log("="*60, CYAN)

        # تشغيل المراحل بالتوازي حيثما أمكن
        with concurrent.futures.ThreadPoolExecutor(max_workers=3) as executor:
            # nmap سريع (إلزامي)
            f1 = executor.submit(self.phase1_nmap_quick)
            f1.result()  # ننتظر nmap أولاً

            # بعد nmap، نشغل فحص nmap شامل إذا لزم الأمر
            if len(self.results["ports"]) < 10:
                executor.submit(self.phase2_nmap_full)

            # فحص الويب والخدمات بالتوازي
            executor.submit(self.phase3_web_scan)
            executor.submit(self.phase4_service_enum)

        # بعد انتهاء الفحوصات الأساسية، نبحث عن الأعلام والمعلومات
        self.phase6_flag_hunting()
        self.phase7_info_extraction()

        # عرض النتائج
        self.show_summary()

        elapsed = time.time() - self.start_time
        self.log(f"⏱️ الزمن الكلي: {elapsed:.2f} ثانية", CYAN)

