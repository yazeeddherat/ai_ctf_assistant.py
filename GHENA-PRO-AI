"""
VETERAN CTF ASSISTANT v6.1 [BUG FIXED]
تم إصلاح مشكلة المتغيرات غير المعرفة (NameError)
"""

import subprocess, sys, re, os, shlex

# 1. تعريف الألوان والتنسيقات (تأكدنا من وجود BOLD هنا)
G = '\033[38;5;82m'; R = '\033[38;5;196m'; Y = '\033[38;5;226m'
C = '\033[38;5;51m'; M = '\033[38;5;201m'; W = '\033[38;5;255m'
BOLD = '\033[1m'; DIM = '\033[2m'; END = '\033[0m'

def cls(): os.system('clear' if os.name == 'posix' else 'cls')

def veteran_banner():
    print(f"{C}┌──────────────────────────────────────────────────────────┐")
    print(f"│  {W}VETERAN CTF ASSISTANT {G}[SABLE - NO ERRORS]{C}            │")
    print(f"│  {M}المساعد الذكي: تم إصلاح خطأ الـ NameError بنجاح{C}          │")
    print(f"└──────────────────────────────────────────────────────────┘{END}")

def explain_ar(title, msg, color=W):
    print(f"\n{color}[{title}]{END} {msg}")

def diagnostic_report(cmd, error_msg):
    explain_ar("تقرير الفشل التقني", "حدث خطأ أثناء تنفيذ الأمر:", R)
    print(f"{Y}الأمر:{END} {cmd}")
    if "not found" in error_msg.lower():
        print(f"{R}[!] التفسير:{END} الأداة غير مثبتة. {G}الحل:{END} sudo apt install {cmd.split()[0]}")
    else:
        print(f"{Y}[i] التفاصيل:{END}\n{DIM}{error_msg}{END}")

def run_command(cmd):
    try:
        args = shlex.split(cmd)
        process = subprocess.Popen(args, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        stdout, stderr = process.communicate(timeout=150)
        if process.returncode != 0:
            diagnostic_report(cmd, stderr)
            return None
        return stdout
    except Exception as e:
        diagnostic_report(cmd, str(e))
        return None

def logic_engine(output, current_cmd, ip):
    if not output: return None, None
    out_low = output.lower()
    if "404 not found" in out_low or "not found" in out_low:
        explain_ar("تعديل المنهجية", "استلمنا 404. سنقوم بالبحث عن Virtual Hosts (VHosts).", C)
        return f"ffuf -u http://{ip} -w /usr/share/wordlists/dirb/common.txt -H 'Host: FUZZ.contrabando.thm' -fs 0", "VHost Enumeration"
    if "open" in out_low and "nmap" in current_cmd.lower():
        ports = re.findall(r'(\d+)/tcp\s+open', output)
        if ports:
            explain_ar("الخطوة التالية", f"وجدت البورتات {ports}. سنقوم بفحص الخدمات.", G)
            return f"nmap -sV -sC -p {','.join(ports)} {ip}", "Deep Scan"
    return None, None

def main():
    cls()
    veteran_banner()
    target_ip = input(f"{C}▸ أدخل IP الهدف: {END}").strip()
    if not target_ip: return

    current_cmd = f"nmap -F --min-rate 1000 {target_ip}"
    desc = "مسح سريع للمنافذ"

    while current_cmd:
        explain_ar("المهمة المطلوبة", desc, G)
        # تم إصلاح هذا السطر لضمان وجود جميع المتغيرات
        print(f"{W}{BOLD}# {current_cmd}{END}")
        
        user_input = input(f"\n{C}تنفيذ (y) / قفز (n) / خروج (q): {END}").lower()
        if user_input == 'y':
            output = run_command(current_cmd)
            if output:
                print(f"\n{DIM}--- [المخرجات] ---\n{output[:800]}\n---{END}")
                current_cmd, desc = logic_engine(output, current_cmd, target_ip)
            else:
                explain_ar("تنبيه", "فشل الأمر. هل نجرب فحص الويب مباشرة؟", Y)
                if input("نعم (y) / لا (n): ").lower() == 'y':
                    current_cmd, desc = logic_engine("404 not found", "nmap", target_ip)
                else: break
        elif user_input == 'n':
            current_cmd, desc = logic_engine("404 not found", "skip", target_ip)
        else: break

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n{R}[!] تم الإيقاف.{END}")
