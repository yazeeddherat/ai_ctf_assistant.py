    def start_attack(self):
        ip = self.ip_entry.get().strip()
        if not ip:
            messagebox.showerror("Error", "Please enter target IP")
            return
        self.current_ip = ip
        self.results = self.reset_results()
        self.results["ip"] = ip
        self.start_time = time.time()
        self.start_btn.config(state=tk.DISABLED, text="⚔️ EXPERT ATTACK IN PROGRESS...")
        self.log_expert(f"\n{'='*70}", GREEN)
        self.log_expert(f"🎯 TARGET: {ip}", CYAN)
        self.log_expert(f"🕒 Started at: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}", WHITE)
        self.log_expert('='*70, GREEN)
        
        self.attack_thread = threading.Thread(target=self.run_expert_attack, args=(ip,))
        self.attack_thread.daemon = True
        self.attack_thread.start()
        
    def run_expert_attack(self, ip):
        try:
            # 1. Reconnaissance
            self.log_expert("\n🔍 [PHASE 1] RECONNAISSANCE - Gathering target information", CYAN)
            out = self.run_cmd(f"nmap -F -sV -T4 {ip}", timeout=300)
            if out:
                for line in out.split('\n'):
                    m = re.search(r'(\d+)/tcp\s+open\s+(\S+)', line)
                    if m:
                        port, svc = int(m.group(1)), m.group(2)
                        self.results["ports"].append(port)
                        self.results["services"][port] = svc
                        self.log_expert(f"   🔓 Port {port}: {svc}", WHITE)
            if not self.results["ports"]:
                self.expert_warning("No open ports found with quick scan. Attempting full port scan...")
                out = self.run_cmd(f"nmap -p- -T4 {ip}", timeout=600)
                if out:
                    for line in out.split('\n'):
                        m = re.search(r'(\d+)/tcp\s+open', line)
                        if m:
                            port = int(m.group(1))
                            self.results["ports"].append(port)
                            self.results["services"][port] = "unknown"
                            self.log_expert(f"   🔓 Port {port}: unknown", WHITE)
                            
            if not self.results["ports"]:
                self.expert_warning("No open ports detected. Target may be down or heavily filtered.")
                self.finish_attack()
                return
                
            # 2. Web enumeration
            web_ports = [p for p in self.results["ports"] if p in [80,443,8080,8443,8000,8888] or 'http' in self.results["services"].get(p,'')]
            if web_ports:
                self.log_expert("\n🌐 [PHASE 2] WEB ENUMERATION - Analyzing web services", CYAN)
                for port in web_ports:
                    self.scan_web_expert(ip, port)
                    
            # 3. Room identification
            self.log_expert("\n🔎 [PHASE 3] ROOM IDENTIFICATION - Cross-referencing with expert database", CYAN)
            room_id, confidence = self.identify_room_expert()
            if room_id:
                self.display_expert_answers(room_id)
                self.expert_note("Even though the room is identified, we will continue with full enumeration for verification.")
            else:
                self.expert_note("Proceeding with full enumeration to gather maximum intelligence.")
                
            # 4. Service enumeration
            self.log_expert("\n📡 [PHASE 4] SERVICE ENUMERATION - Deep dive into services", CYAN)
            self.scan_ftp_expert(ip)
            self.scan_smb_expert(ip)
            self.scan_ssh_expert(ip)
            
            # 5. Flag hunting
            if web_ports:
                self.log_expert("\n🎯 [PHASE 5] FLAG HUNTING - Searching for flags", CYAN)
                self.hunt_flags_expert(ip, web_ports)
                
            # 6. Information extraction
            self.log_expert("\n📋 [PHASE 6] INFORMATION EXTRACTION - Parsing all outputs", CYAN)
            self.extract_info_expert()
            
            # 7. Final summary
            self.log_expert("\n📊 [PHASE 7] EXPERT ANALYSIS COMPLETE", CYAN)
            self.show_expert_summary()
            
            elapsed = time.time() - self.start_time
            self.expert_success(f"Attack completed in {elapsed:.2f} seconds")
            
        except Exception as e:
            self.log_expert(f"❌ Critical error: {e}", YELLOW)
        finally:
            self.finish_attack()
            
    def finish_attack(self):
        self.root.after(0, lambda: self.start_btn.config(state=tk.NORMAL, text="🚀 START ADVANCED ATTACK"))
        self.save_report()

