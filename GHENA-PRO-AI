class GhenaSmartSolver:
    def __init__(self, root):
        self.root = root
        self.root.title("GHENA SMART EASY CTF SOLVER")
        self.root.geometry("1200x850")
        self.root.configure(bg=BLACK)
        
        # تحميل قاعدة البيانات أو إنشاؤها
        self.rooms_db = self.load_db()
        
        self.attack_thread = None
        self.output_queue = queue.Queue()
        self.current_ip = ""
        self.results = self.reset_results()
        
        self.setup_ui()
        self.update_output()
        
    def load_db(self):
        if DB_PATH.exists():
            with open(DB_PATH, 'r', encoding='utf-8') as f:
                return json.load(f)
        else:
            with open(DB_PATH, 'w', encoding='utf-8') as f:
                json.dump(DEFAULT_ROOMS, f, indent=4)
            return DEFAULT_ROOMS.copy()
            
    def reset_results(self):
        return {
            "ip": "",
            "ports": [],
            "services": {},
            "web_techs": set(),
            "directories": set(),
            "cms": None,
            "usernames": set(),
            "passwords": set(),
            "hashes": set(),
            "flags": set(),
            "answers": []
        }
        
    def setup_ui(self):
        top_frame = tk.Frame(self.root, bg=BLACK)
        top_frame.pack(pady=10, fill=tk.X)
        
        title = tk.Label(top_frame, text="GHENA SMART", font=("Courier", 40, "bold"),
