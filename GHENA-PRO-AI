# ========= PRIORITY =========
def priority(services):
    if "http" in services:
        return "HIGH"
    if "ftp" in services:
        return "MEDIUM"
    if "ssh" in services:
        return "MEDIUM"
    return "LOW"

# ========= SOLVER =========
def solver(target, room_name="unknown"):
    print(f"{G}Target:{END} {target}")

    # ===== SCAN =====
    nmap_out = run(f"nmap -sC -sV {target}")
    print(nmap_out[:600])

    ports = parse_nmap(nmap_out)
    services = [p[1] for p in ports]

    print(f"\n{C}[SERVICES]{END} {services}")

    # ===== ROOM TYPE =====
    room = classify_room(room_name, services)
    print(f"{C}[ROOM TYPE]{END} {room}")

    # ===== PRIORITY =====
    print(f"{Y}[PRIORITY]{END} {priority(services)}")

    # ===== WEB =====
    web = web_check(target)
    print(f"{C}[WEB]{END} {web}")

    # ===== HINTS =====
    print(f"\n{Y}[HINTS]{END}")
    for h in exploit_hints(services):
        print("- " + h)

    # ===== ROOM INTELLIGENCE =====
    print(f"\n{R}[ROOM INTELLIGENCE]{END}")
    for i in room_intelligence(room_name, services):
        print("- " + i)

    # ===== ATTACK PATH =====
    print(f"\n{R}[ATTACK PATH]{END}")
    for step in attack_path(services):
        print(step)

    # ===== LOOP =====
    while True:
        choice = input("\n(recon / enum / exit): ").strip()

        if choice == "recon":
            print(run(f"nmap -sC -sV {target}"))

        elif choice == "enum":
            print("\n".join(exploit_hints(services)))

        elif choice == "exit":
            break

