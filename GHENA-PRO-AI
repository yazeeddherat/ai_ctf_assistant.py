    def command_output(self, output, max_lines=5):
        if output:
            lines = output.strip().split('\n')
            for line in lines[:max_lines]:
                if line.strip():
                    self.log(f"      {line.strip()}")
            if len(lines) > max_lines:
                self.log(f"      ... and {len(lines)-max_lines} more lines")
        else:
            self.log("      No output")
            
    # ========== التعرف الدقيق ==========
    def identify_room_precise(self):
        if not self.results["ports"]:
            return None
            
        candidates = []
        for room_id, data in self.rooms_db.items():
            score = 0
            max_score = 0
            
            known_ports = set(data.get("ports", []))
            if known_ports:
                port_match = len(set(self.results["ports"]).intersection(known_ports))
                score += port_match * 10
                max_score += len(known_ports) * 10
                
            if "services" in data and self.results["services"]:
                for port, svc in self.results["services"].items():
                    if str(port) in data["services"] and data["services"][str(port)] in svc:
                        score += 5
                        max_score += 5
                        
            if data.get("cms") and self.results["cms"] and data["cms"] == self.results["cms"]:
                score += 20
                max_score += 20
                
            if data.get("title") and self.results["title"] and data["title"].lower() in self.results["title"].lower():
                score += 15
                max_score += 15
                
            if max_score > 0:
                match_percent = (score / max_score) * 100
                candidates.append((room_id, match_percent, data))
                
        candidates.sort(key=lambda x: x[1], reverse=True)
        
        if candidates and candidates[0][1] >= 60:
            best = candidates[0]
            self.success(f"أفضل تطابق: {best[2].get('name')} بنسبة {best[1]:.1f}%")
            if best[1] >= 90:
                return best[0], best[1]
            else:
                self.warning("تطابق غير مؤكد بنسبة عالية.")
                for i, (rid, perc, rdata) in enumerate(candidates[:3]):
                    if i == 0:
                        continue
                    self.info(f"   {rdata.get('name')}: {perc:.1f}%")
                return best[0], best[1]
        else:
            self.warning("لم يتم العثور على تطابق مؤكد.")
            return None, 0
            
    def display_room_answers(self, room_id, match_percent):
        data = self.rooms_db[room_id]
        self.log(f"\n{'='*60}")
        if match_percent < 90:
            self.warning(f"تطابق جزئي ({match_percent:.1f}%) - قد لا تكون هذه الغرفة صحيحة")
        self.log(f"🎯 الغرفة: {data.get('name', room_id)}")
        self.log('='*60)
        if "answers" in data and data["answers"]:
            self.results["answers"] = data["answers"]
            for ans in data["answers"]:
                self.log(f"  ▶️ {ans}")
        else:
            self.warning("لا توجد إجابات محفوظة لهذه الغرفة.")
            
    # ========== فحص متقدم ==========
    def get_web_title(self, ip, port):
        protocol = 'https' if port in [443,8443] else 'http'
        out = self.run_cmd(f"curl -s {protocol}://{ip}:{port} | grep -i '<title>' | head -1")
        if out:
            match = re.search(r'<title>(.*?)</title>', out, re.IGNORECASE)
            if match:
                return match.group(1).strip()
        return None
        
    def get_cms(self, ip, port):
        protocol = 'https' if port in [443,8443] else 'http'
        out = self.run_cmd(f"whatweb {protocol}://{ip}:{port} --log-verbose=/dev/null")
        if out:
            cms_keywords = ['WordPress', 'Joomla', 'Drupal', 'Magento', 'Simple Image Gallery', 'CMS Made Simple']
            for cms in cms_keywords:
                if cms.lower() in out.lower():
                    return cms
        return None
        
    def scan_web(self, ip, port):
        protocol = 'https' if port in [443,8443] else 'http'
        self.info(f"فحص الويب على المنفذ {port}...")
        out = self.run_cmd(f"whatweb {protocol}://{ip}:{port} --log-verbose=/dev/null")
        if out:
            techs = re.findall(r'([A-Za-z0-9]+(?:-[A-Za-z0-9]+)*)\[', out)
            for t in techs:
                self.results["web_techs"].add(t)
            self.command_output(out)
        out = self.run_cmd(f"gobuster dir -u {protocol}://{ip}:{port} -w /usr/share/wordlists/dirb/common.txt -t 50 -q")
        if out:
            dirs = re.findall(r'/(\S+)\s+\(Status: 200\)', out)
            for d in dirs:
                self.results["directories"].add(d)
            if dirs:
                self.success(f"الدلائل المكتشفة: {', '.join(dirs[:5])}")
        title = self.get_web_title(ip, port)
        if title:
            self.results["title"] = title
            self.success(f"عنوان الصفحة: {title}")
        cms = self.get_cms(ip, port)
        if cms:
            self.results["cms"] = cms
            self.success(f"CMS: {cms}")
            
    def scan_ftp(self, ip):
        if 21 not in self.results["ports"]:
            return
        self.info("فحص FTP...")
        out = self.run_cmd(f"nmap --script ftp-anon -p 21 {ip}")
        if "Anonymous FTP login allowed" in out:
            self.success("FTP anonymous login مسموح")
            ftp_out = self.run_cmd(f"echo -e 'anonymous\\n\\nls\\nbye' | ftp -n {ip} 2>/dev/null")
            files = re.findall(r'^-rw-r--r--.*?(\S+)$', ftp_out, re.MULTILINE)
            if files:
                self.success(f"الملفات: {', '.join(files)}")
                
    def scan_smb(self, ip):
        if any(p in [139,445] for p in self.results["ports"]):
            self.info("فحص SMB...")
            out = self.run_cmd(f"enum4linux -a {ip}")
            if out:
                users = re.findall(r'user:\[(\S+)\]', out)
                for u in users:
                    self.results["usernames"].add(u)
                if users:
                    self.success(f"المستخدمون: {', '.join(users)}")
                    
    def scan_ssh(self, ip):
        if 22 in self.results["ports"]:
            self.info("فحص SSH...")
            try:
                sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                sock.settimeout(5)
                sock.connect((ip, 22))
                banner = sock.recv(1024).decode()
                sock.close()
                self.success(f"Banner: {banner.strip()}")
            except:
                pass
                
    def hunt_flags(self, ip, web_ports):
        self.info("البحث عن الأعلام في المسارات الشائعة...")
        flag_paths = [
            "/flag.txt", "/root/flag.txt", "/root/root.txt", "/root.txt",
            "/home/*/flag.txt", "/home/*/user.txt", "/user.txt",
            "/var/www/flag.txt", "/tmp/flag.txt", "/.flag",
            "/secret.txt"
        ]
        for port in web_ports:
            protocol = 'https' if port in [443,8443] else 'http'
            for path in flag_paths:
                out = self.run_cmd(f"curl -s {protocol}://{ip}:{port}{path}")
                if out and len(out) < 500:
                    patterns = [r'THM\{[^}]+\}', r'flag\{[^}]+\}', r'FLAG\{[^}]+\}',
                                r'G00d j0b', r'W3ll d0n3']
                    for pat in patterns:
                        matches = re.findall(pat, out)
                        for m in matches:
                            self.results["flags"].add(m)
                            self.success(f"العلم: {m}")
                            
    def extract_info(self):
        for f in Path(".").glob("*.txt"):
            if f.name.startswith("GHENA_"):
                continue
            try:
                content = f.read_text(encoding='utf-8', errors='ignore')
                user_pats = [r'username:\s*(\S+)', r'user:\s*(\S+)', r'login:\s*(\S+)']
                for pat in user_pats:
                    matches = re.findall(pat, content, re.IGNORECASE)
                    for m in matches:
                        self.results["usernames"].add(m.strip())
                pass_pats = [r'password:\s*(\S+)', r'pass:\s*(\S+)', r'([a-f0-9]{32})']
                for pat in pass_pats:
                    matches = re.findall(pat, content, re.IGNORECASE)
                    for m in matches:
                        if len(m) > 4:
                            self.results["passwords"].add(m.strip())
            except:
                pass
                
