def show_cmd(cmd):
    print(f"{G}# {cmd}{END}")

def run_cmd(cmd):
    try:
        res = subprocess.run(cmd, shell=True, text=True, capture_output=True, timeout=120)
        return res.stdout, res.returncode
    except: return "ERROR", 1

# ── المنهجية الذكية (Autonomous Logic) ─────────────────────────

def smart_analyze(output, current_cmd, ip):
    cmd_low = current_cmd.lower()
    
    # حالة 1: فشل العثور على ملفات (مثل 404 في robots.txt)
    if "404 not found" in output.lower() or len(output.strip()) < 50:
        if "robots.txt" in cmd_low:
            explain("بما أن ملف robots.txt غير موجود، الخادم قد يعتمد على Virtual Hosts. سأقوم الآن بفحص الـ Subdomains المخفية.")
            return f"ffuf -u http://{ip} -w /usr/share/wordlists/dirb/common.txt -H 'Host: FUZZ.target.thm' -fs 0", "فحص الـ Virtual Hosts لتجاوز صفحة 404"
        
        if "ffuf" in cmd_low:
            explain("الفحص السطحي لم يعطِ نتائج. سأنتقل الآن للفحص العميق (Recursive) مع إضافة امتدادات ملفات برمجية.")
            return f"ffuf -u http://{ip}/FUZZ -w /usr/share/wordlists/dirb/common.txt -e .php,.txt,.bak,.config -t 50", "بحث عن ملفات حساسة (.bak, .config)"

    # حالة 2: تحليل مخرجات Nmap
    if "nmap" in cmd_low:
        ports = re.findall(r'(\d+)/tcp\s+open', output)
        if ports:
            explain(f"وجدت بورتات مفتوحة: {ports}. سأبدأ بفحص الخدمات (Service Enumeration) لتبين الإصدارات والثغرات العامة.")
            return f"nmap -sV -sC -p {','.join(ports)} {ip}", "فحص الإصدارات والسكربتات الافتراضية"

    # حالة 3: إذا وجدت بورت 21 (FTP)
    if "21/tcp" in output and "ftp" in output.lower():
        explain("وجدنا منفذ FTP. سأحاول تسجيل الدخول كمجهول (Anonymous) وجلب قائمة الملفات آلياً.")
        return f"nmap --script ftp-anon -p 21 {ip}", "محاولة دخول FTP مجهول"

    # حالة التوقف أو النجاح
    explain("المسار الحالي انتهى. أنصحك بفحص يدوي لثغرات Logic أو البحث عن Usernames في الويب.")
    return None, None

