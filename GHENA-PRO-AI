#!/usr/bin/env python3
import requests
import subprocess
import shlex
import re
import os
import datetime

# ========= CONFIG =========
API_KEY = os.getenv("OPENAI_API_KEY")
MODEL = "gpt-4.1-mini"

if not API_KEY:
    print("[-] Missing OPENAI_API_KEY")
    exit()

# ========= UI =========
G="\033[92m"; R="\033[91m"; Y="\033[93m"; C="\033[96m"; END="\033[0m"

# ========= STATE MACHINE =========
state = {
    "phase": "recon",
    "shell": False,
    "privilege": "unknown",
    "services": []
}

history = []
notes = []

SYSTEM = """
You are an expert CTF solver (TryHackMe / HackTheBox).

Rules:
- Give ONLY next step
- Be extremely short
- Focus on current phase
- No explanations
"""

# ========= AI =========
def ask_ai(data):
    history.append({"role":"user","content":data})

    r = requests.post(
        "https://api.openai.com/v1/chat/completions",
        headers={"Authorization":f"Bearer {API_KEY}"},
        json={
            "model": MODEL,
            "messages":[{"role":"system","content":SYSTEM}] + history
        }
    )

    reply = r.json()["choices"][0]["message"]["content"]
    history.append({"role":"assistant","content":reply})
    return reply

# ========= RUN =========
def run(cmd):
    print(f"{Y}[RUN]{END} {cmd}")
    p = subprocess.Popen(shlex.split(cmd),
                         stdout=subprocess.PIPE,
                         stderr=subprocess.PIPE,
                         text=True)
    out, err = p.communicate()
    return out if out else err

# ========= PARSERS =========
def parse_nmap(data):
    return re.findall(r'(\d+)/tcp\s+open\s+([^\s]+)', data)

def detect_web(output):
    o = output.lower()
    if "404" in o:
        return "vhost"
    if "?page=" in o:
        return "lfi"
    if "login" in o:
        return "auth"
    if "upload" in o:
        return "upload"
    return "unknown"

def detect_priv(output):
    if "uid=0" in output:
        return "root"
    if "uid=" in output:
        return "user"
    return "unknown"

# ========= BRAIN =========
def decide_next_step(output):
    global state

    # Update state
    if "nmap" in output:
        state["services"] = parse_nmap(output)

    if "www-data" in output or "shell" in output:
        state["shell"] = True

    if "uid=" in output:
        state["privilege"] = detect_priv(output)

    # ===== PHASE LOGIC =====
    if state["phase"] == "recon":
        return "Run nmap with scripts + version scan"

    if state["phase"] == "enum":
        return "Check web directories / parameters / vhosts"

    if state["shell"]:
        state["phase"] = "privesc"
        return "Start privilege escalation checks"

    if state["phase"] == "privesc":
        return "Check sudo -l, SUID, cron jobs, kernel exploits"

    return "Manual analysis required"

# ========= WEB ANALYZER =========
def web_analyzer(target):
    try:
        r = requests.get(f"http://{target}", timeout=5)
        t = r.text.lower()

        if "404" in t:
            return "Possible VHOST"
        if "login" in t:
            return "Login panel"
        if "upload" in t:
            return "File upload"
        if "?id=" in t or "?page=" in t:
            return "Possible injection point"

        return "No obvious vectors"

    except:
        return "Web unreachable"

# ========= LOOP =========
def solver(target):
    print(f"{G}Target:{END} {target}")

    # ===== RECON =====
    output = run(f"nmap -sC -sV {target}")
    print(output[:600])

    state["services"] = parse_nmap(output)

    # ===== WEB =====
    web_info = web_analyzer(target)
    print(f"{C}[Web]{END} {web_info}")

    state["phase"] = "enum"

    # ===== MAIN LOOP =====
    while True:
        print(f"\n{C}[STATE]{END} {state}")

        suggestion = decide_next_step(output)
        ai = ask_ai(f"""
State: {state}
Output: {output[:500]}
Suggestion: {suggestion}
What is next step?
""")

        print(f"{G}[AI]{END} {ai}")

        choice = input("(run / next / save / exit): ").strip()

        if choice == "run":
            output = run(ai)

        elif choice == "next":
            state["phase"] = "enum" if state["phase"] == "recon" else state["phase"]

        elif choice == "save":
            notes.append({"time":str(datetime.datetime.now()),"step":ai})
            print("[+] saved")

        elif choice == "exit":
            break

# ========= REPORT =========
def report():
    print(f"{Y}\n=== REPORT ==={END}")
    for n in notes:
        print(n)

# ========= MAIN =========
def main():
    print(f"""{G}
LEVIATHAN v3 — SMART CTF SOLVER
THM / HackTheBox MODE
{END}""")

    target = input("Target IP: ").strip()
    solver(target)
    report()

if __name__ == "__main__":
    main()
